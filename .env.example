# ============================================================================
# CogniTwin — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env

# ── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2

# ── Scrum Master local model ─────────────────────────────────────────────────
# Path inside the Docker container where the trained Scrum Master model is
# mounted.  Set automatically by docker-compose.dev.yml — do not change here.
# To use the model locally, place the trained model files in:
#   ./models/scrum_model/        (repo-relative, gitignored)
# then run:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build
#
# Leave unset to fall back to Ollama llama3.2 (no model files needed).
SCRUM_MODEL_PATH=/app/models/scrum_model

# ── CogniTwin role-based access control ────────────────────────────────────
# These keys are sent by LibreChat as  Authorization: Bearer <key>  and mapped
# to a role by the backend.  Change them in production — never use defaults.
#
#   student role  → sees only cognitwin-student-llm
#   agile role    → sees cognitwin-product-owner, scrum, developer, composer
#   admin role    → sees all models
#
# Share the agile key only with project-track users.
# The legacy key "cognitwin" still works and maps to the student role.
COGNITWIN_STUDENT_KEY=cognitwin-student
COGNITWIN_AGILE_KEY=cognitwin-agile
COGNITWIN_ADMIN_KEY=cognitwin-admin

# ── CogniTwin Portal — Workspace seçim sayfası (port 8080) ─────────────────
# Kullanıcılar önce bu URL'yi açar: http://<host>:8080
# Buradan Student veya Agile Workspace'e yönlendirilir.
PORTAL_PORT=8080

# ── LibreChat — Student instance (port 3900) ────────────────────────────────
# Students are directed to http://<host>:3900
# Only the "CogniTwin Student" endpoint appears in their model picker.
LIBRECHAT_PORT=3900
DOMAIN_CLIENT=http://localhost:3900
DOMAIN_SERVER=http://localhost:3900
MONGO_URI=mongodb://mongodb:27017/LibreChat
MEILI_MASTER_KEY=change-me
DEBUG_LOGGING=true
DEBUG_CONSOLE=false
ALLOW_REGISTRATION=true
NO_INDEX=true
TRUST_PROXY=1
JWT_SECRET=change-this-jwt-secret
JWT_REFRESH_SECRET=change-this-jwt-refresh-secret

# ── LibreChat — Agile instance (port 3901) ──────────────────────────────────
# Project-track users are directed to http://<host>:3901
# Only the "CogniTwin Agile" endpoint appears — Composer, PO, SM, Developer.
# Separate MongoDB database keeps agile and student accounts fully isolated.
AGILE_PORT=3901
AGILE_DOMAIN_CLIENT=http://localhost:3901
AGILE_DOMAIN_SERVER=http://localhost:3901
AGILE_MONGO_URI=mongodb://mongodb:27017/LibreChat_Agile
