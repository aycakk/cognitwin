# ============================================================================
# CogniTwin — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env

# ── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2

# ── Scrum Master local model ─────────────────────────────────────────────────
# Path inside the Docker container where the trained Scrum Master model is
# mounted.  Set automatically by docker-compose.dev.yml — do not change here.
# To use the model locally, place the trained model files in:
#   ./models/scrum_model/        (repo-relative, gitignored)
# then run:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build
#
# Leave unset to fall back to Ollama llama3.2 (no model files needed).
SCRUM_MODEL_PATH=/app/models/scrum_model

# ── LibreChat ───────────────────────────────────────────────────────────────
LIBRECHAT_PORT=3900
DOMAIN_CLIENT=http://localhost:3900
DOMAIN_SERVER=http://localhost:3900
MONGO_URI=mongodb://mongodb:27017/LibreChat
MEILI_MASTER_KEY=change-me
DEBUG_LOGGING=true
DEBUG_CONSOLE=false
ALLOW_REGISTRATION=true
NO_INDEX=true
TRUST_PROXY=1
JWT_SECRET=change-this-jwt-secret
JWT_REFRESH_SECRET=change-this-jwt-refresh-secret

# â”€â”€ Workspace API keys â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
COGNITWIN_STUDENT_KEY=cognitwin-student
COGNITWIN_AGILE_KEY=cognitwin-agile
COGNITWIN_HR_KEY=cognitwin-hr
COGNITWIN_LEGACY_KEY=cognitwin

# â”€â”€ Agile/HR workspace ports â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
AGILE_PORT=3901
HR_PORT=3902
PORTAL_PORT=8080

# â”€â”€ n8n automation (HR) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
N8N_ENABLED=true
# Highest-priority single URL for all HR actions.
# /webhook/hr-action  = production path; workflow must be Published/Active in n8n.
# /webhook-test/hr-action = manual n8n testing only; requires "Listen for test event" to be active.
# Local (host machine): HR_N8N_WEBHOOK_URL=http://localhost:5678/webhook/hr-action
# Docker backend:       HR_N8N_WEBHOOK_URL=http://n8n:5678/webhook/hr-action
HR_N8N_WEBHOOK_URL=http://localhost:5678/webhook/hr-action
# Fallback single webhook URL when HR_N8N_WEBHOOK_URL is not set.
N8N_WEBHOOK_URL=
# Base URL fallback when per-action URLs are not set.
N8N_WEBHOOK_BASE_URL=http://n8n:5678/webhook
N8N_SHORTLIST_WEBHOOK=
N8N_SLACK_WEBHOOK=
# Slack Incoming Webhook URL used by the n8n "Notify Slack" HTTP Request node.
# Set this as a workflow variable in n8n: Settings → Variables → SLACK_HR_WEBHOOK_URL
# Do NOT commit the real URL here. Paste it directly in n8n Variables.
SLACK_HR_WEBHOOK_URL=
N8N_OUTREACH_WEBHOOK=
N8N_INTERVIEW_WEBHOOK=
N8N_MATCH_WEBHOOK=
N8N_CV_WEBHOOK=

# Optional local n8n UI exposure
N8N_PORT=5678
N8N_PUBLIC_WEBHOOK_URL=http://localhost:5678/
