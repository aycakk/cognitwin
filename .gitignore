# Ozel ayarlar ve sifreler
.env
infra/librechat/.env
infra/librechat/.env.local

# LibreChat yerel veri ve ciktilari
infra/librechat/data-node/
infra/librechat/logs/
infra/librechat/meili_data_v1.35.1/
infra/librechat/uploads/
infra/librechat/images/

# Python kutuphane klasoru
venv/
env/
bin/
lib/
.deps/
.api-venv/
.venv-clean/

# Gecici dosyalar ve cache
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Environment secrets (never commit — use .env.example as template)
.env

# Veritabani dosyalari
*.db
*.sqlite3

# ChromaDB
static/chromadb/

# Runtime session storage (per-agent outputs — regenerated on each run)
data/sessions/

# Filelock runtime files
*.lock

# OS files
.DS_Store
Thumbs.db

# Locally trained model weights (large binary files — never commit)
# Each developer places their own copy in models/scrum_model/
models/scrum_model/*
!models/scrum_model/.gitkeep
*.safetensors
*.bin
training_args.bin

# Runtime live footprint events (PII-masked, regenerated per session)
src/data/masked/footprints_live.jsonl

# Runtime sprint state, backups, history, and agent storage
data/sprint_state.backup.json
data/sprint_state.json.bak-*
data/sprint_history.json
data/student_agent_history.json
data/student_notes.json
data/student/profile.json
data/sprints/state/*.json
data/*.bak-*
