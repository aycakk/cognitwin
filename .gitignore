# Python
__pycache__/
*.pyc
.venv/
venv/

# Environment secrets (never commit — use .env.example as template)
.env

# Tests
tests/

# ChromaDB
static/chromadb/

# Runtime session storage (per-agent outputs — regenerated on each run)
data/sessions/

# Filelock runtime files
*.lock

# OS files
.DS_Store
Thumbs.db

# Locally trained model weights (large binary files — never commit)
# Each developer places their own copy in models/scrum_model/
models/scrum_model/*
!models/scrum_model/.gitkeep
*.safetensors
*.bin
training_args.bin
