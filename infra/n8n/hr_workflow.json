    {
      "parameters": {
        "dataType": "string",
        "value1": "={{$json.body.action_type}}",
        "rules": {
          "rules": [
            { "value2": "shortlist_to_sheets" },
            { "value2": "notify_slack" },
            { "value2": "send_outreach_email" },
            { "value2": "create_calendar_event" },
            { "value2": "log_to_ats" }
          ]
        },
        "fallbackOutput": "extra"
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Route by action_type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            { "name": "status", "value": "placeholder" },
            { "name": "action", "value": "shortlist_to_sheets" },
            { "name": "note", "value": "Replace with Google Sheets node. Use $json.candidate_name, $json.job_title, $json.score, $json.decision from input." }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Shortlist → Sheets (placeholder)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [700, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.SLACK_HR_WEBHOOK_URL }}",
