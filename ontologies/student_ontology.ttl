#    Data properties
#################################################################

###  http://cognitwin.org/student#credits
:credits rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:integer .


###  http://cognitwin.org/student#grade
:grade rdf:type owl:DatatypeProperty ;
       rdfs:range xsd:string .


###  http://cognitwin.org/student#hasDeadline
:hasDeadline rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:dateTime .


###  http://cognitwin.org/student#hasExamDate
:hasExamDate rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:dateTime .


