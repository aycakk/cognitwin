#################################################################

###  http://cognitwin.org/student#hasAssignment
:hasAssignment rdf:type owl:ObjectProperty .


###  http://cognitwin.org/student#hasExam
:hasExam rdf:type owl:ObjectProperty .


###  http://cognitwin.org/student#hasInstructor
:hasInstructor rdf:type owl:ObjectProperty ;
               rdfs:range :Instructor .


###  http://cognitwin.org/student#takesCourse
:takesCourse rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#activityPartOf
<http://www.co-ode.org/ontologies/ont.owl#activityPartOf> rdf:type owl:ObjectProperty ;
                                                          rdfs:subPropertyOf <http://www.co-ode.org/ontologies/ont.owl#partOf> ;
                                                          rdfs:domain <http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/Activity> ;
                                                          rdfs:range <http://cognitwin.org/upper#Course> .


###  http://www.co-ode.org/ontologies/ont.owl#partOf
<http://www.co-ode.org/ontologies/ont.owl#partOf> rdf:type owl:ObjectProperty ;
                                                  rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/departmentPartOf
<http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/departmentPartOf> rdfs:subPropertyOf <http://www.co-ode.org/ontologies/ont.owl#partOf> .


