@prefix agile: <http://example.org/agile#> .
@prefix core: <http://example.org/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix meta: <http://example.org/ontology-engineering#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qc: <http://example.org/quality#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix redo: <http://example.org/reliability#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

agile:AgileCoach_Principle11 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "AgileCoach upholds Principle 11"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Individual assertion that the AgileCoach role upholds Manifesto Principle 11 (self-organising teams) through coaching practices that build team autonomy and reduce external dependency."@en .

agile:AgileManifestoOWL a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "Agile Manifesto Semantic Representation"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://agilemanifesto.org/> ;
    owl:equivalentClass agile:AgileManifesto ;
    skos:definition "Academic and practitioner OWL representations of the Agile Manifesto values and principles, providing semantic grounding for the ManifestoValue and AgilePrinciple classes in this ontology."@en .

agile:AgilePrincipleNumberShape a sh:NodeShape ;
    rdfs:label "Agile Principle Number Shape"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    sh:property [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:maxInclusive 12 ;
            sh:message "AGILE [COMPLETENESS]: AgilePrinciple must have principleNumber between 1 and 12."@en ;
            sh:minCount 1 ;
            sh:minInclusive 1 ;
            sh:path agile:principleNumber ] ;
    sh:targetClass agile:AgilePrinciple .

agile:ArchitecturalEnabler a owl:Class ;
    rdfs:label "Architectural Enabler"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0: Architectural Runway. https://framework.scaledagile.com/architectural-runway/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Enabler ;
    skos:definition """A SAFe Enabler subtype that builds or maintains the Architectural Runway
        — the existing code, components, and technical infrastructure needed to
        implement near-term features without excessive redesign and delay."""@en .

agile:BacklogItemStoryPointShape a sh:NodeShape ;
    rdfs:label "Backlog Item Story Point Shape"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    sh:property [ a sh:PropertyShape ;
            sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:message "AGILE [ESTIMATION]: BacklogItem storyPointValue must be a non-negative integer if present."@en ;
            sh:path agile:storyPointValue ] ;
    sh:targetClass agile:BacklogItem .

agile:BehaviorDrivenDevelopment a owl:Class ;
    rdfs:label "Behavior-Driven Development (BDD)"@en ;
    dcterms:source "North, D. (2006). Introducing BDD. Better Software Magazine. https://dannorth.net/introducing-bdd/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://dannorth.net/introducing-bdd/> ;
    rdfs:subClassOf agile:XPPractice ;
    skos:definition """An agile practice introduced by Dan North extending Test-Driven Development
        with natural-language scenario specifications (Given-When-Then) that bridge
        business understanding and technical implementation, enabling executable
        acceptance tests generated from Gherkin scenarios."""@en .

agile:Bug a owl:Class ;
    rdfs:label "Bug"@en ;
    dcterms:source "Microsoft (2024). Scrum process work item types. Azure DevOps Docs. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogItem ;
    skos:definition """A pre-release defect identified before the Feature reaches production,
        typically discovered during Sprint testing. Bugs live within the active Sprint
        and belong to an in-progress backlog item rather than the Product Backlog."""@en .

agile:BusinessAnalyst a owl:Class ;
    rdfs:label "Business Analyst"@en ;
    dcterms:source "IIBA (2015). Business Analysis Body of Knowledge (BABOK) v3.0."@en ;
    rdfs:comment "Bridge candidate for BABOK v3 BusinessAnalyst role — skos:closeMatch appropriate."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:TeamMember ;
    skos:closeMatch <http://schema.org/Person> ;
    skos:definition "A functional role on an Agile team responsible for eliciting, documenting, and elaborating requirements, bridging stakeholder needs and technical implementation. In Scrum, the BA function is distributed across Product Owner (what/why) and Developers (how), but dedicated BA roles persist in scaled and hybrid organisations."@en .

agile:BusinessRule a owl:Class ;
    rdfs:label "Business Rule"@en ;
    dcterms:source "IIBA (2015). Business Analysis Body of Knowledge (BABOK) v3.0. International Institute of Business Analysis."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Requirement ;
    skos:definition """A specific, testable directive constraining or shaping how the system
        must behave based on organisational policy, regulation, or domain logic —
        not a description of new functionality but a boundary on its implementation."""@en .

agile:CQ1 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ1: What are the four core values of the Agile Manifesto?"@en ;
    agile:answerableBy agile:ManifestoValue ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?v WHERE { ?v rdf:type agile:ManifestoValue . } ORDER BY ?manifestoOrder"@en .

agile:CQ10 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ10: How does SAFe organise teams at the programme level?"@en ;
    agile:answerableBy agile:AgileReleaseTrainConcept ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?art WHERE { ?art rdfs:subClassOf agile:ScaledAgileFramework . FILTER(?art != agile:ScaledAgileFramework) }"@en .

agile:CQ11 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ11: What scaling frameworks exist for enterprise agile adoption?"@en ;
    agile:answerableBy agile:ScalingFramework ;
    dcterms:source "Larman, C. and Vodde, B. (2016). Large-Scale Scrum. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?sf WHERE { ?sf rdfs:subClassOf agile:ScalingFramework . FILTER(?sf != agile:ScalingFramework) }"@en .

agile:CQ12 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ12: What is the relationship between Kanban WIP limits and flow?"@en ;
    agile:answerableBy agile:KanbanMethod ;
    dcterms:source "Anderson, D. (2010). Kanban. Blue Hole Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?k ?wip WHERE { ?k rdf:type agile:KanbanMethod ; agile:wipLimit ?wip . }"@en .

agile:CQ13 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ13: How does DevOps relate to agile delivery practices?"@en ;
    agile:answerableBy agile:DevOps ;
    dcterms:source "Fitzgerald, B. and Stol, K.-J. (2017). Continuous software engineering. Journal of Systems and Software."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?ci ?devops WHERE { ?ci rdf:type agile:ContinuousIntegrationPractice ; agile:enablesDevOps ?devops . }"@en .

agile:CQ14 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ14: What standards bodies govern agile project management?"@en ;
    agile:answerableBy agile:AgileStandard ;
    dcterms:source "PMI (2021). PMBOK Guide 7th Edition."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?std WHERE { ?std rdf:type agile:AgileStandard . }"@en .

agile:CQ15 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ15: What production paradigms historically preceded agile?"@en ;
    agile:answerableBy agile:ProductionParadigm ;
    dcterms:source "Womack, J.P. et al. (1990). The Machine That Changed the World. Free Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?p WHERE { ?p rdfs:subClassOf agile:ProductionParadigm . FILTER(?p != agile:ProductionParadigm) }"@en .

agile:CQ16 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ16: What is the Definition of Done and how does it relate to the Increment?"@en ;
    agile:answerableBy agile:DefinitionOfDone ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?dod ?inc WHERE { ?dod rdf:type agile:DefinitionOfDone ; agile:validatesIncrement ?inc . }"@en .

agile:CQ17 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ17: Which AI and NLP tools augment agile project management?"@en ;
    agile:answerableBy agile:AIAugmentedPM ;
    dcterms:source "Tawosi, V. et al. (2022). Agile effort estimation. IEEE TSE, 49(4)."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?tool WHERE { ?tool rdf:type agile:AgilePMTool ; rdfs:subClassOf* agile:AIAugmentedPM . }"@en .

agile:CQ18 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ18: What are the DORA metrics and which framework defines them?"@en ;
    agile:answerableBy agile:DORAMetric ;
    dcterms:source "Forsgren, N., Humble, J. and Kim, G. (2018). Accelerate. IT Revolution Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?m WHERE { ?m rdfs:subClassOf agile:DORAMetric . }"@en .

agile:CQ19 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ19: What existing ontologies in the literature cover agile concepts?"@en ;
    agile:answerableBy agile:RelatedOntology ;
    dcterms:source "Falbo, R.A. et al. (2015). The Software Engineering Ontology Network. FOIS."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?ro WHERE { ?ro rdf:type agile:RelatedOntology . }"@en .

agile:CQ2 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ2: What are the twelve principles of the Agile Manifesto, ordered by number?"@en ;
    agile:answerableBy agile:AgilePrinciple ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?p ?n WHERE { ?p rdf:type agile:AgilePrinciple ; agile:principleNumber ?n . } ORDER BY ?n"@en .

agile:CQ20 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ20: How does Ontology4Agile integrate with the COM0463 ontology ecosystem?"@en ;
    agile:answerableBy agile:AgileProjectManagement ;
    dcterms:source "Altunel, Y. (2026). COM0463 Ontology Ecosystem Architecture. Istanbul Kültür University."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?o ?imp WHERE { <http://example.org/agile> owl:imports ?imp . }"@en .

agile:CQ21 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ21: What is team velocity and how is it calculated?"@en ;
    agile:answerableBy agile:Velocity ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?team ?vel WHERE { ?team rdf:type agile:ScrumTeam ; agile:teamVelocity ?vel . }"@en .

agile:CQ22 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ22: What are the seven Lean Software Development principles?"@en ;
    agile:answerableBy agile:LeanPrinciple ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?lp WHERE { ?lp rdf:type agile:LeanPrinciple . }"@en .

agile:CQ23 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ23: What activities occur during Backlog Refinement?"@en ;
    agile:answerableBy agile:BacklogRefinement ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?br ?item WHERE { ?br rdf:type agile:BacklogRefinement ; agile:refines ?item . }"@en .

agile:CQ24 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ24: How does Scrumban combine Scrum and Kanban practices?"@en ;
    agile:answerableBy agile:Scrumban ;
    dcterms:source "Kniberg, H. and Skarin, M. (2010). Kanban and Scrum. InfoQ."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?sb WHERE { ?sb rdf:type agile:Scrumban . }"@en .

agile:CQ25 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ25: What XP practices directly support DevOps adoption?"@en ;
    agile:answerableBy agile:ContinuousIntegrationPractice ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?xp ?devops WHERE { ?xp rdf:type agile:XPPractice ; agile:enablesDevOps ?devops . }"@en .

agile:CQ26 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ26: What are the four key Kanban flow metrics and how do they relate to Little's Law?"@en ;
    agile:answerableBy agile:AgileMetric ;
    dcterms:source "Vacanti, D. (2015). Actionable Agile Metrics for Predictability. ActionableAgile Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?metric WHERE { ?m a agile:AgileMetric ; rdfs:label ?metric . FILTER(CONTAINS(LCASE(?metric),'throughput')||CONTAINS(LCASE(?metric),'cycle time')||CONTAINS(LCASE(?metric),'lead time')||CONTAINS(LCASE(?metric),'work item age'))}"@en .

agile:CQ27 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ27: What is the complete PBI type hierarchy from Theme down to Task including Enabler subtypes?"@en ;
    agile:answerableBy agile:BacklogItem ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide.; Beck (1999). XP Explained."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?parent ?child WHERE { ?child rdfs:subClassOf+ agile:BacklogItem . OPTIONAL { ?child rdfs:subClassOf ?parent } } ORDER BY ?parent"@en .

agile:CQ28 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ28: What are the INVEST criteria for well-formed User Stories and how do they relate to the Definition of Ready?"@en ;
    agile:answerableBy agile:INVESTCriteria ;
    dcterms:source "Wake, B. (2003). INVEST in Good Stories. https://xp123.com/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?invest ?dor WHERE { agile:INVESTCriteria a owl:Class . agile:DefinitionOfReady a owl:Class . agile:DefinitionOfReady rdfs:subClassOf+ agile:AgileArtefact }"@en .

agile:CQ29 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ29: What Gherkin scenario components define a Given-When-Then acceptance test?"@en ;
    agile:answerableBy agile:GherkinScenario ;
    dcterms:source "Agile Alliance (2020). Glossary: Given-When-Then. https://www.agilealliance.org/glossary/given-when-then/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?prop WHERE { ?prop rdfs:domain agile:GherkinScenario . ?prop a owl:DatatypeProperty }"@en .

agile:CQ3 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ3: What roles are defined in the Scrum framework?"@en ;
    agile:answerableBy agile:ScrumRole ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?r WHERE { ?r rdfs:subClassOf agile:ScrumRole . }"@en .

agile:CQ30 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ30: What non-SDLC backlog item types can appear in an Agile team backlog alongside User Stories?"@en ;
    agile:answerableBy agile:NonSDLCBacklogItem ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0 Team Backlog. https://framework.scaledagile.com/team-backlog/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?type WHERE { ?type rdfs:subClassOf agile:NonSDLCBacklogItem }"@en .

agile:CQ31 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ31: What are all possible lifecycle states of a BacklogItem and what transitions are allowed?"@en ;
    agile:answerableBy agile:BacklogItemState ;
    dcterms:source "Microsoft (2024). Azure DevOps Scrum process. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?from ?to WHERE { ?from agile:transitionsTo ?to . ?from a agile:BacklogItemState }"@en .

agile:CQ32 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ32: Which backlog items are currently in a Blocked state and what impediments are blocking them?"@en ;
    agile:answerableBy agile:Impediment ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?item ?imp WHERE { ?item agile:hasState agile:State_Blocked . ?item agile:blockedBy ?imp }"@en .

agile:CQ33 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ33: What are the Task-level sub-states within a Sprint and how do they differ from BacklogItem states?"@en ;
    agile:answerableBy agile:TaskStatus ;
    dcterms:source "Atlassian (2024). Jira Software Scrum workflow. https://support.atlassian.com/jira-software-cloud/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?ts WHERE { ?ts a agile:TaskStatus }"@en .

agile:CQ34 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ34: What SDLC functional roles can be members of a CrossFunctionalTeam?"@en ;
    agile:answerableBy agile:TeamMember ;
    dcterms:source "IIBA (2015). Business Analysis Body of Knowledge (BABOK) v3.0."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?role WHERE { ?role rdfs:subClassOf+ agile:TeamMember }"@en .

agile:CQ35 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ35: Which roles bear ownership of GherkinScenarios and AcceptanceCriteria?"@en ;
    agile:answerableBy agile:GherkinScenario ;
    dcterms:source "ISTQB (2023). ISTQB Glossary v4.3. https://glossary.istqb.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?artefact ?role WHERE { ?artefact agile:ownedBy ?role . FILTER(?artefact IN (agile:AcceptanceCriteria, agile:GherkinScenario)) }"@en .

agile:CQ36 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ36: What is the Sprint Goal lifecycle and what determines Met vs NotMet?"@en ;
    agile:answerableBy agile:SprintGoalState ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?state WHERE { ?state a agile:SprintGoalState }"@en .

agile:CQ37 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ37: How does DevelopmentTeam (Scrum 2017) relate to Developer (Scrum 2020)?"@en ;
    agile:answerableBy agile:DevelopmentTeam ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?eq WHERE { agile:DevelopmentTeam owl:equivalentClass ?eq }"@en .

agile:CQ38 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ38: What non-SDLC work items might a DataEngineer or DevSecOpsEngineer own in an Agile team backlog?"@en ;
    agile:answerableBy agile:NonSDLCBacklogItem ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?item ?owner WHERE { ?item rdfs:subClassOf agile:NonSDLCBacklogItem . OPTIONAL { ?item agile:ownedBy ?owner } }"@en .

agile:CQ39 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ39: Which Manifesto Principles are upheld by each Scrum role?"@en ;
    agile:answerableBy agile:ScrumRole ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?role ?principle WHERE { ?role agile:upholds ?principle . ?role rdfs:subClassOf+ agile:AgileRole }"@en .

agile:CQ4 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ4: What events constitute a Sprint in Scrum?"@en ;
    agile:answerableBy agile:ScrumEvent ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?e WHERE { ?e rdfs:subClassOf agile:ScrumEvent . FILTER(?e != agile:ScrumEvent) }"@en .

agile:CQ40 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ40: What is the full Vision → Goal → Backlog → Sprint → Increment → Release delivery chain?"@en ;
    agile:answerableBy agile:ProductVision ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?v ?g ?b ?s ?i ?r WHERE { ?v a agile:ProductVision . ?v agile:derivedInto ?g . ?g agile:achievedVia ?b . ?b agile:containsItem ?item . ?s agile:hasSprintBacklog ?sb . ?s agile:producesIncrement ?i . ?i agile:releasedVia ?r }"@en .

agile:CQ41 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ41: Which Scrum events facilitate which roles, and which principles do they implement?"@en ;
    agile:answerableBy agile:ScrumEvent ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?event ?facilitator ?principle WHERE { ?event agile:facilitatedBy ?facilitator . ?event agile:implementsPrinciple ?principle }"@en .

agile:CQ42 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ42: How are all agile: metrics grounded in the Agile Manifesto?"@en ;
    agile:answerableBy agile:AgileMetric ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?metric ?principle ?manifesto WHERE { ?metric rdfs:subClassOf+ agile:AgileMetric . ?metric agile:implementsPrinciple ?principle . ?metric agile:groundedIn ?manifesto }"@en .

agile:CQ5 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ5: What artefacts does Scrum define and what is each artefact's commitment?"@en ;
    agile:answerableBy agile:ScrumArtefact ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?a ?c WHERE { ?a rdf:type agile:ScrumArtefact ; agile:hasCommitment ?c . }"@en .

agile:CQ6 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ6: How is a Sprint Goal related to the Sprint Backlog?"@en ;
    agile:answerableBy agile:SprintBacklog ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?sb ?sg WHERE { ?sb rdf:type agile:SprintBacklog ; agile:hasCommitment ?sg . ?sg rdf:type agile:Commitment . }"@en .

agile:CQ7 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ7: What is the hierarchy of backlog items from Epic to Task?"@en ;
    agile:answerableBy agile:BacklogItem ;
    dcterms:source "Cohn, M. (2004). User Stories Applied. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?parent ?child WHERE { ?parent agile:decomposesInto ?child . ?parent rdfs:subClassOf* agile:BacklogItem . }"@en .

agile:CQ8 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ8: Which estimation techniques are used in Agile?"@en ;
    agile:answerableBy agile:EstimationTechnique ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?t WHERE { ?t rdfs:subClassOf agile:EstimationTechnique . }"@en .

agile:CQ9 a core:CompetencyQuestion,
        owl:NamedIndividual ;
    rdfs:label "CQ9: What agile frameworks exist beyond Scrum?"@en ;
    agile:answerableBy agile:AgileFramework ;
    dcterms:source "Digital.ai (2022). 16th Annual State of Agile Report. https://digital.ai/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SELECT ?f WHERE { ?f rdfs:subClassOf agile:AgileFramework . FILTER(?f != agile:ScrumFramework && ?f != agile:ScalingFramework) }"@en .

agile:Capability a owl:Class ;
    rdfs:label "Capability"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0 Glossary: Capabilities. https://framework.scaledagile.com/glossary/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:decomposesInto ;
            owl:someValuesFrom agile:Feature ],
        agile:BacklogItem ;
    skos:definition """In SAFe Large Solution, a higher-level system ability spanning multiple
        Agile Release Trains, split into Features for individual ARTs. Capabilities
        describe the ability or quality that a solution must possess or exhibit
        to achieve a business outcome."""@en .

agile:CompetencyQuestionAnswerShape a sh:NodeShape ;
    rdfs:label "Competency Question Answerable Shape"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    sh:property [ a sh:PropertyShape ;
            sh:message "AGILE [CQ]: CompetencyQuestion must have at least one agile:answerableBy link to an ontology class."@en ;
            sh:minCount 1 ;
            sh:path agile:answerableBy ] ;
    sh:targetClass core:CompetencyQuestion .

agile:ComplianceItem a owl:Class ;
    rdfs:label "Compliance Item"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0: Compliance. https://framework.scaledagile.com/compliance/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ComplianceEnabler,
        agile:NonSDLCBacklogItem ;
    skos:definition """A non-SDLC backlog item representing a regulatory, audit, legal, or
        certification obligation that must be tracked and completed alongside feature
        development, treated as a first-class work item with acceptance criteria
        and Definition of Done."""@en .

agile:Constraint a owl:Class ;
    rdfs:label "Constraint"@en ;
    dcterms:source "PMI (2021). PMBOK Guide 7th Edition. Project Management Institute."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Requirement ;
    skos:definition """An external, non-negotiable limit bounding the solution space, imposed
        by legal, budgetary, technology, or time considerations. Constraints differ
        from Business Rules in that they arise from outside the organisation rather
        than from internal policy."""@en .

agile:ContinuousDelivery a owl:Class ;
    rdfs:label "Continuous Delivery"@en,
        "Continuous Delivery (CD)"@en ;
    dcterms:source "Forsgren, N., Humble, J. and Kim, G. (2018). Accelerate. IT Revolution Press."@en,
        "Humble, J. and Farley, D. (2010). Continuous Delivery. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileEngineeringPractice,
        agile:DevOps ;
    owl:equivalentClass meta:ContinuousDeployment ;
    skos:definition "A DevOps practice extending Continuous Integration to ensure that every code change passing the automated test suite is in a deployable state. CD reduces the cost of release by making deployment a routine, low-risk event rather than a periodic high-stakes operation."@en,
        """The DevOps practice of maintaining software in a state where
        it can be safely deployed to production at any time through automated
        build, test, and deployment pipelines."""@en .

agile:ContinuousIntegration a owl:Class ;
    rdfs:label "Continuous Integration"@en ;
    dcterms:source "Fowler, M. (2006). Continuous Integration. https://martinfowler.com/articles/continuousIntegration.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileEngineeringPractice ;
    skos:definition "An XP/DevOps engineering practice in which developers merge code changes into a shared repository multiple times per day, triggering automated build and test pipelines. CI reduces integration risk and provides fast feedback on code quality."@en .

agile:ControlChart a owl:Class ;
    rdfs:label "Control Chart"@en ;
    dcterms:source "Anderson, D.J. (2010). Kanban. Blue Hole Press.; Atlassian (2024). Kanban Metrics."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:definition "A graphical Kanban diagnostic tool plotting individual Cycle Time data points over time with upper and lower control limits, enabling teams to identify process instability, trends, and anomalies in their flow. High variability signals unpredictability in the delivery process."@en .

agile:CrystalMethodology a owl:Class ;
    rdfs:label "Crystal Methodology"@en ;
    dcterms:source "Cockburn, A. (2004). Crystal Clear: A Human-Powered Methodology for Small Teams. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition """A family of agile methodologies developed by Alistair Cockburn
        that scales methodological weight to project size and criticality,
        ranging from Crystal Clear (≤8 people) to Crystal Red (50-100 people),
        emphasising people, interaction, and skills over process."""@en .

agile:CumulativeFlowDiagram a owl:Class ;
    rdfs:label "Cumulative Flow Diagram"@en ;
    dcterms:source "Anderson, D. (2010). Kanban: Successful Evolutionary Change. Blue Hole Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:definition """A stacked area chart showing the quantity of work items in
        each stage of the workflow over time, used in Kanban to visualise
        WIP levels, cycle time trends, and bottlenecks."""@en .

agile:CycleTime a owl:Class ;
    rdfs:label "Cycle Time"@en ;
    dcterms:source "Anderson, D. (2010). Kanban: Successful Evolutionary Change. Blue Hole Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:definition """The elapsed time from when work on a backlog item begins
        to when it is delivered, a key flow metric in Kanban that enables
        predictability of future delivery."""@en .

agile:DCMIRef a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "Dublin Core Metadata Terms (DCMI)"@en ;
    dcterms:source "Dublin Core Metadata Initiative (2020). DCMI Metadata Terms. https://www.dublincore.org/specifications/dublin-core/dcmi-terms/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://www.dublincore.org/specifications/dublin-core/dcmi-terms/> ;
    skos:definition "DCMI dcterms: vocabulary is used throughout this ontology for source citations, provenance, and metadata (dcterms:source, dcterms:creator, dcterms:created), following the ecosystem convention."@en .

agile:DOLCERef a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "DOLCE — Descriptive Ontology for Linguistic and Cognitive Engineering"@en ;
    dcterms:source "Masolo, C. et al. (2003). DOLCE: A Descriptive Ontology for Linguistic and Cognitive Engineering. WonderWeb Deliverable D18. CNR."@en ;
    rdfs:comment "DOLCE IRI http://www.loa.istc.cnr.it/dolce/dolce-lite.owl is not consistently resolvable; alignment is aspirational — BlindSpot BS-1."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "DOLCE's Perdurant category potentially aligns with agile:ScrumEvent (time-extended processes); Endurant with agile:AgileArtefact (space-bound objects). Full alignment not pursued due to non-resolvable IRI in standard tooling environments."@en .

agile:DailyScrum a owl:Class ;
    rdfs:label "Daily Scrum"@en ;
    agile:facilitatedBy agile:ScrumMaster ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScrumEvent ;
    owl:equivalentClass meta:DailyStandup ;
    skos:definition """A fifteen-minute, time-boxed daily event for the Developers
        to inspect progress toward the Sprint Goal, adapt the Sprint Backlog,
        and plan the next twenty-four hours of work."""@en .

agile:DataEngineer a owl:Class ;
    rdfs:label "Data Engineer"@en ;
    dcterms:source "Reis, J. and Housley, M. (2022). Fundamentals of Data Engineering. O'Reilly."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:TeamMember ;
    skos:definition "A functional role responsible for designing, building, and maintaining data pipelines, data models, and analytics infrastructure. Data Engineers manage non-SDLC and SDLC backlog items in data product teams, and their artefacts (pipelines, schemas) are subject to the same Definition of Done as software features."@en .

agile:Defect a owl:Class ;
    rdfs:label "Defect"@en ;
    dcterms:source "Earle, E. (2021). The 6 Backlog Item Types. Medium. https://edwardearle.medium.com/the-6-backlog-item-types-bdd2e1ab450"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogItem ;
    skos:definition """A backlog item representing a problem with an already delivered Feature
        identified in the production environment. A Defect differs from a Bug in that
        it relates to a specific acceptance criterion of a delivered item, and must
        be prioritised alongside new work in the Product Backlog."""@en .

agile:DefinitionOfDoneCondition a owl:Class ;
    rdfs:label "Definition of Done Condition"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileArtefact ;
    skos:definition "An individual, verifiable exit criterion that a backlog item must satisfy to be considered Done. The full set of DefinitionOfDoneConditions constitutes the team's Definition of Done. Examples: all unit tests pass, code reviewed, documentation updated, deployed to staging."@en .

agile:DefinitionOfDone_Principle7 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "DefinitionOfDone operationalises Principle 7"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Individual assertion that the DefinitionOfDone operationalises Manifesto Principle 7 (working software is the primary measure of progress) by providing a verifiable, shared exit criterion that distinguishes truly done work from merely started or partially completed work."@en .

agile:DevSecOpsEngineer a owl:Class ;
    rdfs:label "DevSecOps Engineer"@en ;
    dcterms:source "NIST (2022). DevSecOps Fundamentals Guidebook. https://csrc.nist.gov/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:TeamMember ;
    skos:definition "A functional role integrating security practices into DevOps pipelines, owning security testing, vulnerability scanning, and compliance automation as first-class backlog items. DevSecOps Engineers ensure ComplianceItems and SecurityEnablers are addressed within normal Sprints."@en .

agile:DisciplinedAgile a owl:Class ;
    rdfs:label "Disciplined Agile (DA)"@en ;
    dcterms:source "Ambler, S. and Lines, M. (2012). Disciplined Agile Delivery. IBM Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScalingFramework ;
    skos:definition """A process-decision toolkit owned by PMI that offers a
        library of practices across multiple lifecycle patterns (Scrum, Kanban,
        Lean, continuous delivery), guiding teams in context-sensitive process
        tailoring rather than prescribing a single methodology."""@en .

agile:DynamicSystemsDevelopmentMethod a owl:Class ;
    rdfs:label "Dynamic Systems Development Method (DSDM)"@en ;
    dcterms:source "Stapleton, J. (1997). DSDM: Dynamic Systems Development Method. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition """An agile framework and project delivery methodology using
        MoSCoW prioritisation and timeboxing, now maintained by the Agile
        Business Consortium as AgilePM, widely used in UK public sector."""@en .

agile:Expectation a owl:Class ;
    rdfs:label "Expectation"@en ;
    dcterms:source "IIBA (2015). BABOK v3.0. Chapter 3: Business Analysis Core Concept Model."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Requirement ;
    skos:definition """An implicit, unstated stakeholder assumption about system behaviour that
        has not yet been formalised as a written requirement. Expectations are
        uncovered during backlog refinement and elaboration sessions and represent
        the hidden requirements that cause sprint failures when unaddressed."""@en .

agile:FeatureAcceptanceCriteriaShape a sh:NodeShape ;
    rdfs:label "Feature Acceptance Criteria Shape"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    sh:property [ sh:message "AGILE [SAFe]: Feature must have at least one agile:hasAcceptanceCriteria."@en ;
            sh:minCount 1 ;
            sh:path agile:hasAcceptanceCriteria ] ;
    sh:targetClass agile:Feature .

agile:FeatureDrivenDevelopment a owl:Class ;
    rdfs:label "Feature-Driven Development (FDD)"@en ;
    dcterms:source "Palmer, S.R. and Felsing, J.M. (2002). A Practical Guide to Feature-Driven Development. Prentice Hall."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition """An object-modelling-centric agile method that organises
        development around a feature list derived from a domain model,
        defining five processes: Develop Overall Model, Build Feature List,
        Plan by Feature, Design by Feature, Build by Feature."""@en .

agile:FunctionalRequirement a owl:Class ;
    rdfs:label "Functional Requirement"@en ;
    dcterms:source "ISO/IEC/IEEE 29148:2018. Requirements Engineering. Section 5.2.5."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Requirement ;
    skos:closeMatch qc:FunctionalRequirement ;
    skos:definition """A requirement describing a specific behaviour or function the system
        must exhibit — what the system shall do. Functional requirements map directly
        to User Stories and Features in agile backlogs."""@en .

agile:GherkinScenarioStructureShape a sh:NodeShape ;
    rdfs:label "Gherkin Scenario Structure Shape"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "AGILE [BDD]: GherkinScenario must have givenContext (Given clause)."@en ;
            sh:minCount 1 ;
            sh:path agile:givenContext ],
        [ sh:datatype xsd:string ;
            sh:message "AGILE [BDD]: GherkinScenario must have whenAction (When clause)."@en ;
            sh:minCount 1 ;
            sh:path agile:whenAction ],
        [ sh:datatype xsd:string ;
            sh:message "AGILE [BDD]: GherkinScenario must have thenOutcome (Then clause)."@en ;
            sh:minCount 1 ;
            sh:path agile:thenOutcome ] ;
    sh:targetClass agile:GherkinScenario .

agile:ISO21500_2021 a agile:AgileStandard,
        owl:NamedIndividual ;
    rdfs:label "ISO 21500:2021 Guidance on Project Management"@en ;
    dcterms:source "ISO (2021). ISO 21500:2021 Project Management. International Organization for Standardization. https://www.iso.org/standard/75071.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The 2021 edition of ISO 21500 updated to explicitly recognise agile approaches alongside traditional project management guidance."@en .

agile:IncrementalDelivery a owl:Class ;
    rdfs:label "Incremental Delivery"@en ;
    dcterms:source "Beck, K. et al. (2001). Agile Manifesto. https://agilemanifesto.org/; Schwaber & Sutherland (2020). Scrum Guide."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition "A delivery strategy in which working software is released in successive small Increments, each adding value to the prior release. Each Increment is potentially shippable and satisfies the Definition of Done. Incremental delivery reduces risk, enables early feedback, and aligns with the Agile Manifesto principle of delivering working software frequently."@en .

agile:InfrastructureEnabler a owl:Class ;
    rdfs:label "Infrastructure Enabler"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0: Enablers. https://framework.scaledagile.com/enablers/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Enabler ;
    skos:definition """A SAFe Enabler subtype supporting the building and use of Agile
        development infrastructure — CI/CD pipelines, build systems, test automation
        tooling, and deployment environments required for frequent integration."""@en .

agile:KanbanMethodInd a agile:KanbanMethod,
        owl:NamedIndividual ;
    rdfs:label "Kanban Method (Anderson 2010)"@en ;
    dcterms:source "Anderson, D. (2010). Kanban: Successful Evolutionary Change. Blue Hole Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The Kanban Method as formalised by David Anderson in 2010: six core practices — visualise, limit WIP, manage flow, make policies explicit, implement feedback loops, improve collaboratively."@en .

agile:LeSSInd a agile:LargeScaleScrum,
        owl:NamedIndividual ;
    rdfs:label "Large-Scale Scrum (LeSS)"@en ;
    dcterms:source "Larman, C. and Vodde, B. (2016). Large-Scale Scrum: More with LeSS. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "LeSS as defined by Larman and Vodde: minimal scaling extension for 2-8 Scrum Teams sharing one Product Backlog and one Product Owner."@en .

agile:LeanManufacturingParadigm a owl:Class ;
    rdfs:label "Lean Manufacturing Paradigm"@en ;
    dcterms:source "Ohno, T. (1988). Toyota Production System: Beyond Large-Scale Production. Productivity Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ProductionParadigm ;
    skos:definition """The production philosophy developed by Taiichi Ohno at
        Toyota, embodied in the Toyota Production System, centred on waste
        elimination, just-in-time delivery, pull-based scheduling, and
        continuous improvement (kaizen)."""@en .

agile:LeanPrinciple1_EliminateWaste a agile:LeanPrinciple,
        owl:NamedIndividual ;
    rdfs:label "Lean Principle 1: Eliminate Waste"@en ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Remove all activities in the software development process that do not add value for the customer, including partially done work, extra features, task switching, waiting, and defects."@en .

agile:LeanPrinciple2_BuildQualityIn a agile:LeanPrinciple,
        owl:NamedIndividual ;
    rdfs:label "Lean Principle 2: Build Quality In"@en ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Embed quality assurance practices throughout the development process rather than inspecting quality in at the end; align with the Agile Principle 9 of technical excellence."@en .

agile:LeanPrinciple3_CreateKnowledge a agile:LeanPrinciple,
        owl:NamedIndividual ;
    rdfs:label "Lean Principle 3: Create Knowledge"@en ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Treat software development as a learning process; invest in capturing, sharing, and amplifying knowledge generated through iterative development and experimentation."@en .

agile:LeanPrinciple4_DeferCommitment a agile:LeanPrinciple,
        owl:NamedIndividual ;
    rdfs:label "Lean Principle 4: Defer Commitment"@en ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Delay irreversible design and architectural decisions until the last responsible moment when the most information is available, reducing the cost of change."@en .

agile:LeanPrinciple5_DeliverFast a agile:LeanPrinciple,
        owl:NamedIndividual ;
    rdfs:label "Lean Principle 5: Deliver Fast"@en ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Compress development cycles to maximise learning and customer value delivery, achieving flow through the system by eliminating queues and batch delays."@en .

agile:LeanPrinciple6_RespectPeople a agile:LeanPrinciple,
        owl:NamedIndividual ;
    rdfs:label "Lean Principle 6: Respect People"@en ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Treat team members and customers as intelligent adults capable of making good decisions; create an environment of psychological safety, trust, and continuous learning."@en .

agile:LeanPrinciple7_OptimiseWhole a agile:LeanPrinciple,
        owl:NamedIndividual ;
    rdfs:label "Lean Principle 7: Optimise the Whole"@en ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Focus optimisation on the entire value stream from customer need to delivered product rather than on local sub-process optimisations that produce suboptimal overall outcomes."@en .

agile:ManifestoPrinciple10 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 10: Simplicity"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Simplicity — the art of maximising the amount of work not done — is essential."@en .

agile:ManifestoPrinciple2 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 2: Welcome Change"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Welcome changing requirements, even late in development. Agile processes harness change for the customer's competitive advantage."@en .

agile:ManifestoPrinciple6 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 6: Face-to-Face Conversation"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The most efficient and effective method of conveying information to and within a development team is face-to-face conversation."@en .

agile:ManifestoValueOrderShape a sh:NodeShape ;
    rdfs:label "Manifesto Value Order Shape"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    sh:property [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:maxInclusive 4 ;
            sh:message "AGILE [COMPLETENESS]: ManifestoValue must have manifestoOrder between 1 and 4."@en ;
            sh:minCount 1 ;
            sh:minInclusive 1 ;
            sh:path agile:manifestoOrder ] ;
    sh:targetClass agile:ManifestoValue .

agile:ManifestoValue_RespondingToChangeOverFollowingPlan a agile:ManifestoValue,
        owl:NamedIndividual ;
    rdfs:label "Responding to Change over Following a Plan"@en ;
    agile:manifestoOrder 4 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The fourth Agile Manifesto value asserting that the capacity to adapt to new information about user needs, technology, or market conditions is more valuable than strict adherence to a predetermined plan."@en .

agile:MassProductionParadigm a owl:Class ;
    rdfs:label "Mass Production Paradigm"@en ;
    dcterms:source "Taylor, F.W. (1911). The Principles of Scientific Management. Harper and Brothers."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ProductionParadigm ;
    skos:definition """The manufacturing philosophy pioneered by Frederick Winslow
        Taylor and Henry Ford emphasising standardised, high-volume production
        with strict division of labour and command-and-control management."""@en .

agile:MoSCoW_CouldHave a agile:MoSCoWPriority,
        owl:NamedIndividual ;
    rdfs:label "Could Have"@en ;
    dcterms:source "Stapleton, J. (1997). DSDM: Dynamic Systems Development Method. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "MoSCoW priority level: the backlog item is desirable if capacity permits but has smaller business impact; often the first to be cut."@en .

agile:MoSCoW_MustHave a agile:MoSCoWPriority,
        owl:NamedIndividual ;
    rdfs:label "Must Have"@en ;
    dcterms:source "Stapleton, J. (1997). DSDM: Dynamic Systems Development Method. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "MoSCoW priority level: the backlog item is essential for the current release and the release cannot be considered successful without it."@en .

agile:MoSCoW_ShouldHave a agile:MoSCoWPriority,
        owl:NamedIndividual ;
    rdfs:label "Should Have"@en ;
    dcterms:source "Stapleton, J. (1997). DSDM: Dynamic Systems Development Method. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "MoSCoW priority level: the backlog item is important but not vital; the release is valuable without it but less so."@en .

agile:MoSCoW_WontHave a agile:MoSCoWPriority,
        owl:NamedIndividual ;
    rdfs:label "Won't Have This Time"@en ;
    dcterms:source "Stapleton, J. (1997). DSDM: Dynamic Systems Development Method. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "MoSCoW priority level: the backlog item is agreed out of scope for the current release, explicitly deferred to a future release."@en .

agile:NexusFramework a owl:Class ;
    rdfs:label "Nexus Framework"@en ;
    dcterms:source "Scrum.org (2021). The Nexus Guide. https://www.scrum.org/resources/nexus-guide"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScalingFramework ;
    skos:definition """A Scrum.org scaling extension for 3-9 Scrum Teams working
        on a single Product Backlog, introducing a Nexus Integration Team
        to ensure Done, integrated Increments are produced each Sprint."""@en .

agile:OperationalTask a owl:Class ;
    rdfs:label "Operational Task"@en ;
    dcterms:source "Scaled Agile Inc. (2023). Team Backlog. SAFe 6.0. https://framework.scaledagile.com/team-backlog/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:NonSDLCBacklogItem ;
    skos:definition """A non-SDLC backlog item for infrastructure maintenance, system monitoring,
        incident response, on-call support, or routine operational work that must
        be balanced against feature delivery in the team backlog."""@en .

agile:PMBOKGuide7th a agile:AgileStandard,
        owl:NamedIndividual ;
    rdfs:label "PMBOK Guide 7th Edition (2021)"@en ;
    dcterms:source "PMI (2021). A Guide to the Project Management Body of Knowledge, 7th ed. Project Management Institute."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The 7th edition of the PMBOK Guide adopts a principles-based structure and explicitly integrates agile and hybrid delivery approaches alongside predictive methods."@en .

agile:PMIAgileStandard a agile:AgileStandard,
        owl:NamedIndividual ;
    rdfs:label "PMI Agile Practice Guide (2017)"@en ;
    dcterms:source "PMI and Agile Alliance (2017). Agile Practice Guide. Project Management Institute. https://www.pmi.org/pmbok-guide-standards/practice-guides/agile"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Co-published by PMI and the Agile Alliance in 2017, this guide covers agile and hybrid delivery approaches in the context of the PMBOK framework."@en .

agile:PMIOntoRef a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "PMI PMBOK Knowledge Framework"@en ;
    dcterms:source "PMI (2021). PMBOK Guide 7th Edition. https://www.pmi.org/pmbok-guide-standards"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://www.pmi.org/pmbok-guide-standards> ;
    skos:definition "The PMI's body of knowledge providing the professional standards context for agile project management, including the PMBOK Guide 7th edition and Agile Practice Guide."@en .

agile:PROVORef a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "W3C PROV-O Ontology"@en ;
    dcterms:source "Lebo, T. et al. (2013). PROV-O: The PROV Ontology. W3C Recommendation. https://www.w3.org/TR/prov-o/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://www.w3.org/TR/prov-o/> ;
    skos:definition "The W3C PROV-O provenance ontology enables tracing the lineage of Product Increments through Sprint execution, aligning prov:wasGeneratedBy and prov:wasDerivedFrom with agile artefact provenance."@en .

agile:PairProgramming a owl:Class ;
    rdfs:label "Pair Programming"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained. Addison-Wesley."@en,
        "Williams, L. et al. (2000). Strengthening the case for pair programming. IEEE Software, 17(4)."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileEngineeringPractice,
        agile:XPPractice ;
    skos:definition "An XP engineering practice in which two developers work at a single workstation: one writes code (driver) while the other reviews in real time (navigator). Pair programming improves code quality, accelerates knowledge transfer, and reduces defect rate."@en,
        """The XP practice in which two developers share a single
        workstation, with one writing code (driver) and the other reviewing
        in real time (navigator), improving code quality and knowledge sharing."""@en .

agile:PhilosophyAnchor a owl:Class ;
    rdfs:label "Philosophy Anchor"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileManifesto ;
    skos:definition "A meta-class providing the structural bridge between any agile: concept and its philosophical grounding in the Agile Manifesto, Lean Principles, or related philosophical frameworks. PhilosophyAnchor instances are the terminal nodes in the philosophy reachability graph; all domain concepts reach a philosophy root via subClassOf or property chains that terminate here. This class formalises the epistemological commitment that every Agile practice is grounded in an explicit philosophical stance."@en .

agile:PlanningPoker a owl:Class ;
    rdfs:label "Planning Poker"@en ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:EstimationTechnique ;
    skos:definition """A consensus-based estimation technique in which team members
        privately select story point estimate cards and reveal them simultaneously
        to prevent anchoring bias, triggering discussion when estimates diverge."""@en .

agile:Principle10_Simplicity a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 10: Simplicity"@en ;
    agile:principleNumber 10 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Simplicity — the art of maximising the amount of work not done — is essential."@en .

agile:Principle11_SelfOrganisingTeams a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 11: Self-Organising Teams"@en ;
    agile:principleNumber 11 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The best architectures, requirements, and designs emerge from self-organising teams."@en .

agile:Principle12_RegularAdjustments a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 12: Regular Reflection and Adjustment"@en ;
    agile:principleNumber 12 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "At regular intervals, the team reflects on how to become more effective, then tunes and adjusts its behaviour accordingly."@en .

agile:Principle1_CustomerSatisfaction a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 1: Customer Satisfaction through Early and Continuous Delivery"@en ;
    agile:principleNumber 1 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Our highest priority is to satisfy the customer through early and continuous delivery of valuable software."@en .

agile:Principle2_WelcomeChange a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 2: Welcome Changing Requirements"@en ;
    agile:principleNumber 2 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Welcome changing requirements, even late in development. Agile processes harness change for the customer's competitive advantage."@en .

agile:Principle3_FrequentDelivery a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 3: Frequent Delivery of Working Software"@en ;
    agile:principleNumber 3 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Deliver working software frequently, from a couple of weeks to a couple of months, with a preference for the shorter timescale."@en .

agile:Principle4_WorkTogether a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 4: Business and Developers Work Together Daily"@en ;
    agile:principleNumber 4 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Business people and developers must work together daily throughout the project."@en .

agile:Principle5_MotivatedIndividuals a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 5: Build Projects Around Motivated Individuals"@en ;
    agile:principleNumber 5 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Build projects around motivated individuals. Give them the environment and support they need, and trust them to get the job done."@en .

agile:Principle6_FaceToFaceCommunication a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 6: Face-to-Face Communication"@en ;
    agile:principleNumber 6 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The most efficient and effective method of conveying information to and within a development team is face-to-face conversation."@en .

agile:Principle7_WorkingSoftware a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 7: Working Software as Primary Measure of Progress"@en ;
    agile:principleNumber 7 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Working software is the primary measure of progress."@en .

agile:Principle8_SustainablePace a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 8: Sustainable Pace of Development"@en ;
    agile:principleNumber 8 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Agile processes promote sustainable development. The sponsors, developers, and users should be able to maintain a constant pace indefinitely."@en .

agile:Principle9_TechnicalExcellence a agile:AgilePrinciple,
        owl:NamedIndividual ;
    rdfs:label "Principle 9: Continuous Attention to Technical Excellence"@en ;
    agile:principleNumber 9 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Continuous attention to technical excellence and good design enhances agility."@en .

agile:ProductVision_Value3 a agile:ManifestoValueClass,
        owl:NamedIndividual ;
    rdfs:label "ProductVision expresses Value 3"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Individual assertion that the ProductVision artefact expresses Manifesto Value 3 (Customer Collaboration over Contract Negotiation) by providing a shared, negotiated long-term purpose rather than a fixed contractual specification."@en .

agile:ProgramIncrementPlanning a owl:Class ;
    rdfs:label "Program Increment Planning (PI Planning)"@en ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:belongsToFramework ;
            owl:someValuesFrom agile:ScaledAgileFramework ],
        agile:ScrumEvent ;
    skos:definition """A two-day face-to-face (or remote) event in SAFe in which
        all teams on an Agile Release Train plan together, identifying
        cross-team dependencies and setting Programme Increment objectives."""@en .

agile:QAEngineer a owl:Class ;
    rdfs:label "QA Engineer"@en ;
    dcterms:source "ISO/IEC/IEEE 29119-1:2022. Software and Systems Engineering — Software Testing."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Tester ;
    skos:definition "A functional role focused on quality assurance processes, test automation, non-functional testing, and continuous quality improvement across the development value stream. Broader than Tester: QA Engineers own the test strategy and tooling in addition to executing tests."@en .

agile:Refactor a owl:Class ;
    rdfs:label "Refactor"@en ;
    dcterms:source "Fowler, M. (1999). Refactoring: Improving the Design of Existing Code. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogItem,
        agile:XPPractice ;
    skos:definition """A backlog item or XP practice representing the improvement of internal
        code structure without changing external behaviour, reducing complexity
        and technical debt to support sustainable development pace."""@en .

agile:RefinementActivity a owl:Class ;
    rdfs:label "Refinement Activity"@en ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogRefinement ;
    skos:definition """An atomic activity performed during Backlog Refinement: decompose a
        large item, estimate an item in story points, clarify acceptance criteria,
        re-prioritise relative value, remove obsolete items, or add newly discovered
        items to the Product Backlog."""@en .

agile:ReleaseTrainEngineer a owl:Class ;
    rdfs:label "Release Train Engineer"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:comment "Bridge candidate for SAFe ReleaseTrainEngineer — direct SAFe-to-Scrum bridge at programme level."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileCoach ;
    skos:definition "In SAFe, the servant leader and chief Scrum Master for the Agile Release Train. The RTE facilitates PI Planning, ART Syncs, and System Demos, and coaches ART-level practices and execution."@en .

agile:RetroTechnique a owl:Class ;
    rdfs:label "Retrospective Technique"@en ;
    dcterms:source "Derby, E. and Larsen, D. (2006). Agile Retrospectives. Pragmatic Bookshelf."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScrumEvent ;
    skos:definition "A facilitation method used during Sprint Retrospectives to elicit team reflections, such as Start/Stop/Continue, 4Ls (Liked/Learned/Lacked/Longed For), Sailboat, or Mad/Sad/Glad. The Scrum Master selects and rotates techniques to prevent retrospective fatigue."@en .

agile:RoadmapState_Archived a agile:ProductRoadmapState,
        owl:NamedIndividual ;
    rdfs:label "Archived"@en ;
    dcterms:source "Pichler, R. (2016). Strategize. Pichler Consulting."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Terminal state of a Product Roadmap superseded by a newer version."@en .

agile:RoadmapState_Draft a agile:ProductRoadmapState,
        owl:NamedIndividual ;
    rdfs:label "Draft"@en ;
    dcterms:source "Pichler, R. (2016). Strategize. Pichler Consulting."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Initial state of a Product Roadmap: a working document under development not yet shared with external stakeholders."@en .

agile:RoadmapState_Published a agile:ProductRoadmapState,
        owl:NamedIndividual ;
    rdfs:label "Published"@en ;
    dcterms:source "Pichler, R. (2016). Strategize. Pichler Consulting."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State of a Product Roadmap formally shared with stakeholders as the current planning horizon."@en .

agile:SAFeInd a agile:ScaledAgileFramework,
        owl:NamedIndividual ;
    rdfs:label "Scaled Agile Framework (SAFe 6.0)"@en ;
    agile:adoptionRate 35.0 ;
    agile:versionString "6.0" ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://scaledagileframework.com/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "SAFe as of version 6.0 (2023): Essential, Large Solution, Portfolio, and Full configurations; ART-based delivery in Program Increments; integration of OKRs."@en .

agile:SEON a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "SEON — Software Engineering Ontology Network"@en ;
    dcterms:source "Falbo, R.A. et al. (2015). The Software Engineering Ontology Network. In: Formal Ontology in Information Systems, FOIS 2014."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://seon.inf.ufes.br/> ;
    skos:closeMatch agile:AgileProjectManagement ;
    skos:definition "A network of ontologies for software engineering developed by Falbo et al. at UFES, providing foundational ontology for software processes, artefacts, and roles from which domain-specific agile ontologies can be derived."@en .

agile:SKOSRef a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "SKOS Simple Knowledge Organization System"@en ;
    dcterms:source "Isaac, A. and Summers, E. (2009). SKOS Simple Knowledge Organization System Primer. W3C Note. https://www.w3.org/TR/skos-primer/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://www.w3.org/TR/skos-reference/> ;
    skos:definition "SKOS vocabulary (skos:definition, skos:example, skos:broader, skos:narrower, skos:closeMatch) is used throughout this ontology for definitions, examples, and cross-ontology alignment, following the ecosystem convention established in core_v1_1_0."@en .

agile:SPEM2 a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "SPEM 2.0 — Software and Systems Process Engineering Meta-Model"@en ;
    dcterms:source "OMG (2008). Software and Systems Process Engineering Meta-Model v2.0. https://www.omg.org/spec/SPEM/2.0/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://www.omg.org/spec/SPEM/2.0/> ;
    skos:closeMatch agile:AgileFramework ;
    skos:definition "OMG's meta-model for describing software and systems development processes, whose ProcessComponent concept is closely aligned with agile:AgileFramework's structured practice collections."@en .

agile:SchemaOrgRef a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "Schema.org Vocabulary"@en ;
    dcterms:source "Schema.org Community Group (2024). Schema.org Vocabulary. https://schema.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso schema:Project ;
    skos:closeMatch schema:Project ;
    skos:definition "Schema.org provides schema:Project and schema:SoftwareApplication as broad alignments for agile project and tool concepts, enabling semantic web discovery of agile PM resources."@en .

agile:ScrumFrameworkInd a agile:ScrumFramework,
        owl:NamedIndividual ;
    rdfs:label "Scrum (2020 Scrum Guide)"@en ;
    agile:adoptionRate 87.0 ;
    agile:versionString "2020" ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. Scrum.org. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The Scrum framework as defined in the 2020 Scrum Guide by Ken Schwaber and Jeff Sutherland: three roles, five events, three artefacts with commitments."@en .

agile:ScrumGuide2020 a agile:AgileStandard,
        owl:NamedIndividual ;
    rdfs:label "Scrum Guide 2020"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The definitive guide to Scrum, authored by Ken Schwaber and Jeff Sutherland, published November 2020. Introduces commitments for each artefact, renames Development Team to Developers."@en .

agile:ScrumGuideOntology a agile:RelatedOntology,
        owl:NamedIndividual ;
    rdfs:label "Scrum Guide (Schwaber and Sutherland 2020)"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://scrumguides.org/> ;
    skos:definition "The normative specification of Scrum as published by Schwaber and Sutherland. Provides the definitional source for all Scrum classes, roles, events, and artefacts in this ontology."@en .

agile:ScrumOfScrumsMaster a owl:Class ;
    rdfs:label "Scrum of Scrums Master"@en ;
    dcterms:source "Sutherland, J. (2014). Scrum: The Art of Doing Twice the Work in Half the Time. Crown."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScrumMaster ;
    skos:definition "A role at scaled agile level facilitating coordination across multiple Scrum Teams through Scrum of Scrums ceremonies, resolving cross-team impediments, and ensuring inter-team dependency management."@en .

agile:ServantLeadership_Principle5 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "ServantLeadership upholds Principle 5"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Individual assertion that the ServantLeadership practice upholds Manifesto Principle 5 (build around motivated individuals) by prioritising the removal of obstacles and provision of support over command-and-control."@en .

agile:SixSigmaParadigm a owl:Class ;
    rdfs:label "Six Sigma Quality Paradigm"@en ;
    dcterms:source "Harry, M.J. and Schroeder, R. (2000). Six Sigma: The Breakthrough Management Strategy. Doubleday."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ProductionParadigm ;
    skos:closeMatch qc:QualityAssuranceProcess ;
    skos:definition """A data-driven quality management methodology targeting
        a defect rate of no more than 3.4 defects per million opportunities,
        organised around the DMAIC (Define, Measure, Analyse, Improve, Control)
        problem-solving cycle. Developed at Motorola in the 1980s."""@en .

agile:SpikeTimeboxShape a sh:NodeShape ;
    rdfs:label "Spike Timebox Shape"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    sh:property [ sh:hasValue true ;
            sh:message "AGILE [XP]: Spike must declare isTimebox=true; unconstrained spikes violate agile principles."@en ;
            sh:minCount 1 ;
            sh:path agile:isTimebox ] ;
    sh:targetClass agile:Spike .

agile:SpotifyModel a owl:Class ;
    rdfs:label "Spotify Model"@en ;
    dcterms:source "Kniberg, H. and Ivarsson, A. (2012). Scaling Agile @ Spotify. https://engineering.atspotify.com/2014/03/spotify-engineering-culture-part-1/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScalingFramework ;
    skos:definition """An organisational design model introduced by Kniberg and
        Ivarsson describing Spotify's squad-tribe-chapter-guild structure
        for balancing team autonomy with enterprise alignment."""@en .

agile:SprintGoalClass a owl:Class ;
    rdfs:label "Sprint Goal"@en ;
    dcterms:source "Pichler, R. (2016). Strategize: Product Strategy and Product Roadmap Practices. Pichler Consulting."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Commitment ;
    skos:definition """A short, one-or-two-sentence description of what the Scrum
        Team plans to achieve during the Sprint, created collaboratively by the
        team and the Product Owner during Sprint Planning, providing cohesive
        intent and enabling autonomous decision-making."""@en .

agile:SprintGoalState_Abandoned a agile:SprintGoalState,
        owl:NamedIndividual ;
    rdfs:label "Abandoned"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State reached when a Sprint is cancelled by the Product Owner before completion because the Sprint Goal has become obsolete."@en .

agile:SprintGoalState_Active a agile:SprintGoalState,
        owl:NamedIndividual ;
    rdfs:label "Active (Sprint Goal)"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State of the Sprint Goal while the Sprint is in progress and the team is working toward achieving it."@en .

agile:SprintGoalState_Met a agile:SprintGoalState,
        owl:NamedIndividual ;
    rdfs:label "Met"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Terminal positive state: the Sprint ended with the Sprint Goal achieved and a usable Increment produced."@en .

agile:SprintGoalState_NotMet a agile:SprintGoalState,
        owl:NamedIndividual ;
    rdfs:label "Not Met"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Terminal negative state: the Sprint ended but the Sprint Goal was not achieved. The team and Product Owner decide how to proceed in the retrospective."@en .

agile:SprintPlanning a owl:Class ;
    rdfs:label "Sprint Planning"@en ;
    agile:facilitatedBy agile:ScrumMaster ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:produces ;
            owl:someValuesFrom agile:SprintBacklog ],
        agile:ScrumEvent ;
    owl:equivalentClass meta:DailyStandup ;
    skos:closeMatch meta:DailyStandup ;
    skos:definition """The time-boxed event (max 8 hours for a one-month Sprint)
        in which the Scrum Team collaborates to define the Sprint Goal,
        select Product Backlog items, and plan how the work will be done."""@en .

agile:SprintReview a owl:Class ;
    rdfs:label "Sprint Review"@en ;
    agile:facilitatedBy agile:ProductOwner ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScrumEvent ;
    skos:definition """The informal meeting at the end of the Sprint in which the
        Scrum Team and stakeholders inspect the Sprint's outcome, gather feedback,
        and adapt the Product Backlog. Maximum 4 hours for a one-month Sprint."""@en .

agile:Sprint_Principle3 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Sprint implements Principle 3"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Individual assertion that the Sprint event structure implements Manifesto Principle 3 (deliver working software frequently) through its fixed timebox producing a usable Increment every 1–4 weeks."@en .

agile:Stakeholder a owl:Class ;
    rdfs:label "Stakeholder"@en ;
    dcterms:source "Schwaber & Sutherland (2020). Scrum Guide. https://scrumguides.org/; PMI (2021). PMBOK Guide 7th Edition."@en ;
    rdfs:comment "Bridge candidate for core:Stakeholder — rdfs:subClassOf declared."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileRole,
        core:Stakeholder ;
    skos:definition "Any person, group, or organisation with an interest in or affected by the product. Stakeholders participate in Sprint Reviews and provide feedback on the Increment. The Product Owner represents stakeholder interests to the Scrum Team."@en .

agile:State_New a agile:BacklogItemState,
        owl:NamedIndividual ;
    rdfs:label "New"@en ;
    agile:transitionsTo agile:State_Cancelled,
        agile:State_Refined ;
    dcterms:source "Microsoft (2024). Azure DevOps Scrum process workflow. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:comment "Lifecycle transition: New → Cancelled"@en,
        "Lifecycle transition: New → Refined"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Initial state of a backlog item: created but not yet refined or estimated."@en .

agile:StoryPoints a owl:Class ;
    rdfs:label "Story Points"@en ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric,
        agile:EstimationTechnique ;
    skos:definition """A relative estimation unit representing a backlog item's
        size in terms of complexity, effort, and risk compared to other items,
        typically scaled using the Fibonacci sequence (1, 2, 3, 5, 8, 13, 21)."""@en .

agile:TaskStatus_Blocked a agile:TaskStatus,
        owl:NamedIndividual ;
    rdfs:label "Blocked (Task)"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State of a Task that cannot proceed because of a dependency, missing information, or external impediment. Raised in Daily Scrum for Scrum Master action."@en .

agile:TaskStatus_Done a agile:TaskStatus,
        owl:NamedIndividual ;
    rdfs:label "Done (Task)"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Terminal state of a Task: all work is complete, acceptance criteria met, and the contributing BacklogItem moves toward Done once all its tasks are done."@en .

agile:TaskStatus_InProgress a agile:TaskStatus,
        owl:NamedIndividual ;
    rdfs:label "In Progress (Task)"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State of a Task actively being worked on by one or more Developers during the current Sprint iteration."@en .

agile:TaskStatus_InReview a agile:TaskStatus,
        owl:NamedIndividual ;
    rdfs:label "In Review (Task)"@en ;
    dcterms:source "Atlassian (2024). Jira Software Scrum workflow. https://support.atlassian.com/jira-software-cloud/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State of a Task submitted for code review, peer review, or test verification before being declared Done. Common in Pull-Request workflows."@en .

agile:TaskStatus_ToDo a agile:TaskStatus,
        owl:NamedIndividual ;
    rdfs:label "To Do"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Initial state of a Task: identified and added to the Sprint Backlog during Sprint Planning but not yet started by any Developer."@en .

agile:TechLead a owl:Class ;
    rdfs:label "Tech Lead"@en ;
    dcterms:source "Larman, C. and Vodde, B. (2016). Large-Scale Scrum (LeSS). Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Architect ;
    skos:definition "A senior Developer who provides technical direction and mentoring within the team without hierarchical authority. The Tech Lead typically owns coding standards, architectural decision records, and coordinates technical dependencies across teams in multi-ART contexts."@en .

agile:TechnicalDebt a owl:Class ;
    rdfs:label "Technical Debt"@en ;
    dcterms:source "Cunningham, W. (1992). The WyCash Portfolio Management System. OOPSLA '92 Experience Report. https://doi.org/10.1145/157709.157715"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogItem ;
    skos:definition """A backlog item representing accumulated code quality shortcuts or
        deferred architectural improvements that must eventually be remediated.
        Technical Debt, like financial debt, accrues interest — the longer it
        remains unaddressed the greater the cost of remediation."""@en .

agile:TechnicalDebt_Principle9 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "TechnicalDebt violates Principle 9"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Individual assertion linking TechnicalDebt to Manifesto Principle 9 (continuous attention to technical excellence). Technical debt represents a deviation from this principle and its accumulation is a signal that the team is compromising technical excellence for short-term delivery."@en .

agile:TestDrivenDevelopment a owl:Class ;
    rdfs:label "Test-Driven Development"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained. Addison-Wesley."@en,
        "Beck, K. (2002). Test-Driven Development: By Example. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileEngineeringPractice,
        agile:XPPractice ;
    skos:definition "An XP engineering practice in which developers write a failing automated test before writing the production code that makes it pass, then refactor. The Red-Green-Refactor cycle ensures test coverage and emergent design."@en,
        """The XP practice of writing automated unit tests before
        writing the implementation code they validate, driving design through
        the red-green-refactor cycle."""@en .

agile:UXDesigner a owl:Class ;
    rdfs:label "UX Designer"@en ;
    dcterms:source "Gothelf, J. and Seiden, J. (2013). Lean UX. O'Reilly."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:UIDesigner ;
    skos:definition "A functional role specialising in user experience research, journey mapping, usability testing, and information architecture. UX Designers typically work one Sprint ahead of the development team to ensure designs are ready (a practice called 'Dual-Track Agile' or 'Sprint Zero')."@en .

agile:achievedVia a owl:ObjectProperty ;
    rdfs:label "achieved via"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ProductGoalClass ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductBacklog ;
    skos:definition "Relates a ProductGoal to the ProductBacklog that serves as the plan for achieving it. The Product Backlog commitment IS the ProductGoal, meaning the backlog's ordered items represent the team's bet on how to reach the goal."@en .

agile:adoptionRate a owl:DatatypeProperty ;
    rdfs:label "adoption rate (%)"@en ;
    dcterms:source "Digital.ai (2022). 16th Annual State of Agile Report. https://digital.ai/resource-center/analyst-reports/state-of-agile-report/"@en ;
    rdfs:domain agile:AgileFramework ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "The percentage of surveyed organisations reporting use of this agile framework, as recorded in the most recent State of Agile survey."@en .

agile:appliedTo a owl:ObjectProperty ;
    rdfs:label "applied to"@en ;
    dcterms:source "Anderson, D.J. (2010). Kanban: Successful Evolutionary Change. Blue Hole Press."@en ;
    rdfs:domain agile:WIPLimit ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:KanbanBoard ;
    skos:definition "Relates a WIPLimit policy to the KanbanBoard or workflow stage where the constraint is enforced. The WIPLimit restricts concurrent work items per column, enforcing pull-based flow and triggering swarm behaviour when downstream columns reach capacity."@en .

agile:blockedDurationHours a owl:DatatypeProperty ;
    rdfs:label "blocked duration hours"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "Elapsed hours a backlog item or task has been in the Blocked state. A key flow health indicator: high average blocked duration signals systemic impediments requiring organisational intervention."@en .

agile:businessValueScore a owl:DatatypeProperty ;
    rdfs:label "business value score"@en ;
    dcterms:source "Microsoft (2024). Azure DevOps PBI field: Business Value. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:positiveInteger ;
    skos:definition "A numeric score expressing the relative business value of a backlog item compared to other items, used by the Product Owner for prioritisation."@en .

agile:constrainedBy a owl:ObjectProperty ;
    rdfs:label "constrained by"@en ;
    dcterms:source "ISO/IEC 25010:2011. SQuaRE Quality Model."@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:NonFunctionalRequirement ;
    skos:definition "Relates a backlog item to the Non-Functional Requirements that constrain its implementation, such as performance, security, or availability requirements."@en .

agile:contains a owl:ObjectProperty ;
    rdfs:label "contains"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:domain agile:ProgramIncrement,
        agile:Release ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductIncrement,
        agile:Sprint ;
    skos:definition "Relates a ProgramIncrement to the Sprints it comprises, or a Release to the ProductIncrements it bundles. In SAFe, a PI contains four to six Sprints. In Scrum, a Release contains one or more consecutive Sprint Increments."@en .

agile:containsItem a owl:ObjectProperty ;
    rdfs:label "contains item"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ProductBacklog,
        agile:SprintBacklog ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:BacklogItem ;
    skos:definition "Relates a Product Backlog or Sprint Backlog to the BacklogItems it currently holds. This property enables SPARQL queries to enumerate all items within a backlog and compute metrics such as backlog size, readiness ratio, and sprint commitment count."@en .

agile:deliveredVia a owl:ObjectProperty ;
    rdfs:label "delivered via"@en ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide. Addison-Wesley."@en ;
    rdfs:domain agile:Feature,
        agile:UserStory ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProgramIncrement,
        agile:Release ;
    skos:definition "Relates a Feature to the Program Increment within which it is planned to be delivered by an Agile Release Train."@en .

agile:deploymentFrequency a owl:DatatypeProperty ;
    rdfs:label "deployment frequency"@en ;
    dcterms:source "Forsgren, N., Humble, J. and Kim, G. (2018). Accelerate. IT Revolution Press."@en ;
    rdfs:domain agile:DevOps ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "DORA metric: the number of deployments to production per unit time, indicating delivery cadence and CI/CD maturity."@en .

agile:derivedInto a owl:ObjectProperty ;
    rdfs:label "derived into"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ProductVision ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductGoalClass ;
    skos:definition "Relates a ProductVision to the ProductGoal(s) derived from it. The ProductVision articulates the long-term purpose of the product; ProductGoals are intermediate milestones on the path to that vision, each representing a Sprint-series target communicated through the Product Backlog."@en .

agile:derivesFrom a owl:ObjectProperty ;
    rdfs:label "derives from"@en ;
    dcterms:source "Pichler (2016). Strategize.; Scrum Guide 2020."@en ;
    rdfs:domain agile:AcceptanceCriteria,
        agile:AcceptanceTest,
        agile:ProductGoalClass ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:GherkinScenario,
        agile:ProductVision ;
    skos:definition "Relates the ProductGoal to the ProductVision from which it is derived, establishing the strategic alignment chain: Vision → Goal → Backlog."@en .

agile:enablesDevOps a owl:ObjectProperty ;
    rdfs:label "enables DevOps"@en ;
    dcterms:source "Fitzgerald, B. and Stol, K.-J. (2017). Continuous software engineering. Journal of Systems and Software, 123."@en ;
    rdfs:domain agile:ContinuousIntegrationPractice ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:DevOps ;
    skos:definition "Relates the Continuous Integration practice to the DevOps capability it enables, forming part of the CI/CD pipeline."@en .

agile:estimatedIn a owl:ObjectProperty ;
    rdfs:label "estimated in"@en ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:EstimationTechnique ;
    skos:definition "Relates a backlog item to the estimation technique used to assess its relative size or effort."@en .

agile:expressesValue a owl:ObjectProperty ;
    rdfs:label "expresses value"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:domain agile:AgileArtefact,
        agile:AgileFramework,
        agile:AgileRole,
        agile:BacklogItem,
        agile:ScrumArtefact,
        agile:ScrumEvent ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ManifestoValue ;
    skos:definition "Relates an agile framework to the Agile Manifesto core value(s) that its design most strongly embodies."@en .

agile:facilitatedBy a owl:ObjectProperty ;
    rdfs:label "facilitated by"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ScrumEvent ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileRole ;
    rdfs:subPropertyOf core:responsibleRole ;
    skos:definition "Relates a ScrumEvent to the AgileRole that facilitates or leads it. The ScrumMaster facilitates SprintPlanning, DailyScrum, and SprintRetrospective. The ProductOwner leads the SprintReview. Both roles collaborate in BacklogRefinement."@en .

agile:governanceModel a owl:ObjectProperty ;
    rdfs:label "governance model"@en ;
    dcterms:source "REDO v2.4.6 Safeguard Framework. http://example.org/reliability#"@en ;
    rdfs:domain owl:Ontology ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range owl:Ontology ;
    skos:definition "Relates this ontology to the governance ontology (REDO) that defines its verification and quality assurance process."@en .

agile:governedByStandard a owl:ObjectProperty ;
    rdfs:label "governed by standard"@en ;
    dcterms:source "PMI (2021). PMBOK Guide, 7th edition. Project Management Institute."@en ;
    rdfs:domain agile:AgileFramework ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileStandard ;
    rdfs:subPropertyOf core:governedBy ;
    skos:definition "Relates an agile framework to the standards body, professional certification, or normative document that governs or recognises its use."@en .

agile:governs a owl:ObjectProperty ;
    rdfs:label "governs"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:domain agile:Release ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductIncrement ;
    skos:definition "Relates a Release to the ProductIncrement(s) it bundles and delivers. A Release may include one or more Increments from consecutive Sprints. The Release governs versioning, deployment scope, and stakeholder communication."@en .

agile:groundedIn a owl:ObjectProperty ;
    rdfs:label "grounded in"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:domain agile:AgileProjectManagement ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileManifesto ;
    rdfs:subPropertyOf core:isBasedOn ;
    skos:closeMatch dcterms:source ;
    skos:definition "Asserts that an Agile concept, practice, or management approach is philosophically rooted in the Agile Manifesto or one of its derivative frameworks. This property provides the top-level epistemic anchor connecting all agile: concepts to their philosophical origin."@en .

agile:guidedBy a owl:ObjectProperty ;
    rdfs:label "guided by"@en ;
    dcterms:source "Greenleaf (1977). Servant Leadership.; Scrum Guide 2020."@en ;
    rdfs:domain agile:AgileRole ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ServantLeadership ;
    skos:definition "Relates the ScrumMaster or AgileCoach role to the ServantLeadership philosophy that defines their conduct."@en .

agile:hasArtefactState a owl:ObjectProperty ;
    rdfs:label "has artefact state"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:AgileArtefact ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ArtefactState ;
    skos:definition "Relates any AgileArtefact to its current ArtefactState. Generalisable across artefact types: BacklogItem → BacklogItemState, Sprint → SprintGoalState, ProductRoadmap → ProductRoadmapState."@en .

agile:hasMoSCoWPriority a owl:ObjectProperty ;
    rdfs:label "has MoSCoW priority"@en ;
    dcterms:source "Stapleton, J. (1997). DSDM: Dynamic Systems Development Method. Addison-Wesley."@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:MoSCoWPriority ;
    skos:definition "Relates a backlog item to its MoSCoW priority classification (Must, Should, Could, Won't) for release planning."@en .

agile:hasParadigmPredecessor a owl:ObjectProperty ;
    rdfs:label "has paradigm predecessor"@en ;
    dcterms:source "Takeuchi, H. and Nonaka, I. (1986). The new new product development game. Harvard Business Review, 64(1)."@en ;
    rdfs:domain agile:ProductionParadigm ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductionParadigm ;
    rdfs:subPropertyOf core:precedes ;
    skos:definition "Relates a production or development paradigm to the historical paradigm from which it evolved or in reaction to which it was developed."@en .

agile:hasRelatedOntology a owl:ObjectProperty ;
    rdfs:label "has related ontology"@en ;
    dcterms:source "Gruber, T.R. (1993). A translation approach to portable ontology specifications. Knowledge Acquisition, 5(2)."@en ;
    rdfs:domain agile:AgileProjectManagement ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:RelatedOntology ;
    rdfs:subPropertyOf core:derivedFrom ;
    skos:definition "Relates this ontology or a concept within it to a related ontology from the literature, used for alignment and interoperability documentation."@en .

agile:hasSprint a owl:ObjectProperty ;
    rdfs:label "has sprint"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ScrumFramework ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:Sprint ;
    skos:definition "Relates a Scrum project or product to the Sprints executed in its delivery."@en .

agile:hasSprintBacklog a owl:ObjectProperty ;
    rdfs:label "has Sprint Backlog"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:Sprint ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:SprintBacklog ;
    skos:definition "Relates a Sprint to its Sprint Backlog — the set of Product Backlog items selected for the Sprint, plus the plan for delivering the Sprint Increment. The Sprint Backlog is the sole property of the Developers and is updated throughout the Sprint as new work is discovered."@en .

agile:hasSprintGoal a owl:ObjectProperty ;
    rdfs:label "has Sprint Goal"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:Sprint ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:SprintGoal ;
    skos:definition "Relates a Sprint to its Sprint Goal — the single objective for the Sprint that creates coherence and focus. The Sprint Goal is a commitment by the Developers and created during Sprint Planning."@en .

agile:hasSprintGoalState a owl:ObjectProperty ;
    rdfs:label "has sprint goal state"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:Sprint ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:SprintGoalState ;
    skos:definition "Relates a Sprint to the state of its Sprint Goal: Active, Met, NotMet, or Abandoned. Determined at Sprint Review."@en .

agile:hasState a owl:ObjectProperty ;
    rdfs:label "has state"@en ;
    dcterms:source "Microsoft (2024). Azure DevOps Scrum process workflow. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:BacklogItemState ;
    skos:definition "Relates a backlog item to its current lifecycle state in the progression from New to Done."@en .

agile:hasWIPLimit a owl:ObjectProperty ;
    rdfs:label "has WIP limit"@en ;
    dcterms:source "Anderson, D. (2010). Kanban: Successful Evolutionary Change. Blue Hole Press."@en ;
    rdfs:domain agile:KanbanMethod ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileMetric ;
    skos:definition "Relates a Kanban workflow stage to its explicitly defined Work-In-Progress (WIP) limit, controlling flow and exposing bottlenecks."@en .

agile:identifiesImpediment a owl:ObjectProperty ;
    rdfs:label "identifies impediment"@en ;
    dcterms:source "Schwaber & Sutherland (2020). Scrum Guide."@en ;
    rdfs:domain agile:ScrumEvent ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:Impediment ;
    skos:definition "Relates a ScrumEvent (typically Daily Scrum or Retrospective) to an Impediment raised during that event."@en .

agile:implementsPrinciple a owl:ObjectProperty ;
    rdfs:label "implements principle"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/principles.html"@en ;
    rdfs:domain agile:AgileArtefact,
        agile:AgileEngineeringPractice,
        agile:AgileMetric,
        agile:AgilePractice,
        agile:ArtefactState,
        agile:BacklogItem,
        agile:Commitment,
        agile:ScrumArtefact,
        agile:ScrumEvent,
        agile:ScrumRole ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgilePrinciple ;
    skos:definition "Relates an agile practice to the Agile Manifesto principle(s) it operationalises."@en .

agile:improvementPriority a owl:DatatypeProperty ;
    rdfs:label "improvement priority"@en ;
    dcterms:source "SAFe 6.0. Iteration Retrospective. https://framework.scaledagile.com/iteration-retrospective/"@en ;
    rdfs:domain agile:ImprovementAction ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:positiveInteger ;
    skos:definition "Integer rank of an ImprovementAction selected during Retrospective; lower numbers indicate higher priority items to add to the next Sprint Backlog."@en .

agile:isBlocked a owl:DatatypeProperty ;
    rdfs:label "is blocked"@en ;
    dcterms:source "Schwaber & Sutherland (2020). Scrum Guide."@en ;
    rdfs:domain agile:Impediment ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:boolean ;
    skos:definition "Boolean flag indicating that an Impediment is formally blocking a backlog item from progressing, requiring Scrum Master intervention."@en .

agile:isFullTime a owl:DatatypeProperty ;
    rdfs:label "is full time"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:domain agile:TeamMember ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:boolean ;
    skos:definition "Boolean indicating whether a TeamMember is allocated full-time to the Agile team (true) or is a part-time contributor (false). Part-time allocation reduces effective team capacity and should be reflected in Sprint velocity."@en .

agile:leadTimeForChanges a owl:DatatypeProperty ;
    rdfs:label "lead time for changes (hours)"@en ;
    dcterms:source "Forsgren, N., Humble, J. and Kim, G. (2018). Accelerate. IT Revolution Press."@en ;
    rdfs:domain agile:DevOps ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "DORA metric: the elapsed time in hours from code commit to code running in production, measuring the speed of the delivery pipeline."@en .

agile:leadTimeHours a owl:DatatypeProperty ;
    rdfs:label "lead time hours"@en ;
    dcterms:source "Anderson, D.J. (2010). Kanban. Blue Hole Press."@en ;
    rdfs:domain agile:LeadTime ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "Total elapsed time in hours from when a backlog item entered the system (New state) to when it was delivered to the customer."@en .

agile:manifestoSource a owl:ObjectProperty ;
    rdfs:label "manifesto source"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:domain agile:AgileFramework ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileManifesto ;
    skos:definition "Relates an AgileFramework or AgileStandard to the AgileManifesto as its epistemic source document. All Scrum, SAFe, Kanban, and XP frameworks explicitly derive from or align with the Manifesto's values and principles."@en .

agile:measuredBy a owl:ObjectProperty ;
    rdfs:label "measured by"@en ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:domain agile:Sprint ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileMetric ;
    rdfs:subPropertyOf core:assessedBy ;
    skos:definition "Relates a Sprint to the agile metrics used to assess its progress and outcomes."@en .

agile:measuredFor a owl:ObjectProperty ;
    rdfs:label "measured for"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:AgileMetric ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:KanbanBoard,
        agile:ProductBacklog,
        agile:Sprint ;
    skos:definition "Relates an AgileMetric to the Sprint, ProductBacklog, or KanbanBoard context for which it is computed. For example, VelocityMetric is measured for a Sprint; Throughput and LeadTime are measured for a KanbanBoard workflow column."@en .

agile:memberOf a owl:ObjectProperty ;
    rdfs:label "member of"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:TeamMember ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:CrossFunctionalTeam ;
    skos:definition "Relates a TeamMember to the CrossFunctionalTeam or ScrumTeam they belong to."@en .

agile:operatedIn a owl:ObjectProperty ;
    rdfs:label "operated in"@en ;
    dcterms:source "Leffingwell (2018). SAFe 4.5 Reference Guide."@en ;
    rdfs:domain agile:AgileReleaseTrain ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ValueStream ;
    skos:definition "Relates an Agile Release Train to the ValueStream within which it operates and delivers value."@en .

agile:ownedBy a owl:ObjectProperty ;
    rdfs:label "owned by"@en ;
    dcterms:source "PMI (2021). PMBOK Guide 7th Edition."@en ;
    rdfs:domain agile:AcceptanceCriteria,
        agile:AgileArtefact,
        agile:BacklogItem,
        agile:GherkinScenario,
        agile:ProductBacklog,
        agile:ProductIncrement,
        agile:SprintBacklog ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileRole,
        agile:ProductOwner ;
    skos:definition "Relates a backlog item, artefact, or practice to the specific role that bears primary accountability for it. Distinct from performedBy which covers contributors; ownedBy captures single-point accountability."@en .

agile:performedBy a owl:ObjectProperty ;
    rdfs:label "performed by"@en ;
    dcterms:source "PMI (2021). PMBOK Guide 7th Edition."@en ;
    rdfs:domain agile:AgileArtefact,
        agile:ProductIncrement,
        agile:SprintBacklog,
        agile:Task ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileRole,
        agile:Developer ;
    skos:definition "Relates an AgileArtefact or BacklogItem to the AgileRole responsible for its creation or maintenance, enabling RACI-style accountability tracing."@en .

agile:plansWith a owl:ObjectProperty ;
    rdfs:label "plans with"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:domain agile:ProductRoadmap ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProgramIncrement ;
    skos:definition "Relates a ProductRoadmap to the ProgramIncrement(s) that represent its near-term planning horizon. In SAFe, the Roadmap is the primary input to PI Planning. Each PI on the Roadmap corresponds to a defined quarter of committed features and objectives."@en .

agile:precedesSprint a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "precedes sprint"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:Sprint ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:Sprint ;
    rdfs:subPropertyOf core:precedes ;
    skos:definition "Relates one Sprint to the immediately subsequent Sprint in the sequence of a product's development."@en .

agile:producesImprovementAction a owl:ObjectProperty ;
    rdfs:label "produces improvement action"@en ;
    dcterms:source "SAFe 6.0. Iteration Retrospective."@en ;
    rdfs:domain agile:SprintRetrospective ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ImprovementAction ;
    skos:definition "Relates a SprintRetrospective to the ImprovementActions it produced."@en .

agile:refines a owl:ObjectProperty ;
    rdfs:label "refines"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:BacklogRefinement ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:BacklogItem ;
    skos:definition "Relates the Backlog Refinement event to the Product Backlog items it processes to make them Ready for Sprint Planning."@en .

agile:releasedVia a owl:ObjectProperty ;
    rdfs:label "released via"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ProductIncrement ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:Release ;
    skos:definition "Relates a ProductIncrement to the Release event through which it is made available to users or stakeholders. In Scrum, every Increment is potentially releasable; the ProductOwner decides whether to actually release it. In SAFe, Increments are bundled into Program Increment releases."@en .

agile:remainingWork a owl:DatatypeProperty ;
    rdfs:label "remaining work"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:SprintBacklog ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "The amount of work (story points or hours) remaining in the Sprint Backlog at a given point in the Sprint, used to drive the burndown chart."@en .

agile:removedBy a owl:ObjectProperty ;
    rdfs:label "removed by"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:Impediment ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileRole ;
    skos:definition "Relates an Impediment to the AgileRole responsible for resolving it. In Scrum, the ScrumMaster is accountable for impediment removal; in SAFe, the Release Train Engineer escalates cross-team impediments. This property enables accountability reporting: which impediments were resolved by which role."@en .

agile:removesImpediment a owl:ObjectProperty ;
    rdfs:label "removes impediment"@en ;
    dcterms:source "Schwaber & Sutherland (2020). Scrum Guide."@en ;
    rdfs:domain agile:ScrumMaster ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:Impediment ;
    skos:definition "Relates the ScrumMaster to an Impediment that has been resolved through servant leadership."@en .

agile:requiresSkill a owl:ObjectProperty ;
    rdfs:label "requires skill"@en ;
    dcterms:source "IIBA (2015). Business Analysis Body of Knowledge (BABOK) v3.0."@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:TeamMember ;
    skos:definition "Relates a BacklogItem or Task to the functional role whose skill set is required to implement it, enabling capacity and skill-gap analysis during Sprint Planning."@en .

agile:satisfies a owl:ObjectProperty ;
    rdfs:label "satisfies"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ProductIncrement ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:SprintGoal ;
    owl:inverseOf agile:satisfiedBy ;
    skos:definition "Relates a ProductIncrement to the SprintGoal it fulfils. If the Increment produced in a Sprint meets the Sprint Goal, the SprintGoalState transitions to Met. If not, it transitions to NotMet. This property is the formal link between delivery artefact and committed objective."@en .

agile:satisfiesINVEST a owl:ObjectProperty ;
    rdfs:label "satisfies INVEST"@en ;
    dcterms:source "Wake, B. (2003). INVEST in Good Stories. https://xp123.com/articles/invest-in-good-stories-and-smart-tasks/"@en ;
    rdfs:domain agile:BacklogItem,
        agile:UserStory ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:INVESTCriteria ;
    skos:definition "Relates a User Story to the INVEST criteria assessment confirming it is well-formed and ready for Sprint Planning."@en .

agile:sprintDurationWeeks a owl:DatatypeProperty ;
    rdfs:label "sprint duration (weeks)"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:Sprint ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:positiveInteger ;
    skos:definition "The fixed duration of a Sprint in calendar weeks, constrained to be at most four weeks. A value of 1 or 2 is most commonly recommended."@en .

agile:stateEnteredAt a owl:DatatypeProperty ;
    rdfs:label "state entered at"@en ;
    dcterms:source "Atlassian (2024). Jira Software Scrum workflow. https://support.atlassian.com/jira-software-cloud/"@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:dateTime ;
    skos:definition "ISO 8601 datetime at which a backlog item or task entered its current state. Used for Cycle Time calculation: stateEnteredAt(InProgress) to stateEnteredAt(Done)."@en .

agile:teamSize a owl:DatatypeProperty ;
    rdfs:label "team size"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:CrossFunctionalTeam,
        agile:ScrumTeam ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:positiveInteger ;
    skos:definition "The number of TeamMember instances on a CrossFunctionalTeam. Per the Scrum Guide 2020, optimal Scrum Team size is 10 or fewer members."@en,
        "The total number of members in a Scrum Team, recommended to be between 3 and 9 (Developers only) to balance skill breadth with coordination overhead."@en .

agile:teamVelocity a owl:DatatypeProperty ;
    rdfs:label "team velocity"@en ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:domain agile:ScrumTeam ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "The average number of story points completed by a Scrum Team per Sprint, derived from the rolling average of recent Sprint completions."@en .

agile:throughputPerWeek a owl:DatatypeProperty ;
    rdfs:label "throughput per week"@en ;
    dcterms:source "Vacanti, D. (2015). Actionable Agile Metrics for Predictability."@en ;
    rdfs:domain agile:Throughput ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "The number of backlog items completed by the team per calendar week, used as the primary flow metric for Kanban forecasting."@en .

agile:tracksProgress a owl:ObjectProperty ;
    rdfs:label "tracks progress"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:BurndownChart,
        agile:BurnupChart ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductIncrement,
        agile:Sprint ;
    skos:definition "Relates a progress-tracking artefact (BurndownChart, BurnupChart) to the Sprint or ProductIncrement whose remaining or completed work it visualises. The BurndownChart tracks Sprint-level remaining work; the BurnupChart tracks cumulative completion against total Product Backlog scope."@en .

agile:transitionsTo a owl:ObjectProperty ;
    rdfs:label "transitions to"@en ;
    dcterms:source "Microsoft (2024). Azure DevOps Scrum process. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:domain agile:BacklogItemState ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:BacklogItemState ;
    rdfs:subPropertyOf core:nextState ;
    skos:definition "Defines an allowed lifecycle state transition for a backlog item or task. For example: State_Ready transitionsTo State_InProgress. This property enables a formal state machine to be derived from the ontology."@en .

agile:upholds a owl:ObjectProperty ;
    rdfs:label "upholds"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:domain agile:AgileRole ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ManifestoPrincipleClass ;
    skos:closeMatch <http://schema.org/valueReference> ;
    skos:definition "Relates an AgileRole to the Manifesto Principle(s) that the role is specifically designed to embody, protect, or advance. For example, ScrumMaster upholds Principle 11 (self-organising teams) and Principle 5 (motivated individuals). This property enables principle-accountability tracing."@en .

agile:usesTool a owl:ObjectProperty ;
    rdfs:label "uses tool"@en ;
    dcterms:source "Atlassian (2024). Jira Software. https://www.atlassian.com/software/jira"@en ;
    rdfs:domain agile:AgileProjectManagement ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgilePMTool ;
    skos:definition "Relates an agile delivery practice or framework to the software tool that supports or automates it."@en .

agile:validatesIncrement a owl:ObjectProperty ;
    rdfs:label "validates increment"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:DefinitionOfDone ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductIncrement ;
    rdfs:subPropertyOf core:validates ;
    skos:definition "Relates the Definition of Done to the Product Increment it qualifies; an Increment may only be considered Done and releasable if it satisfies the DoD."@en .

agile:velocityAverage a owl:DatatypeProperty ;
    rdfs:label "velocity average"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:VelocityMetric ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "The rolling average of story points completed per Sprint, computed over the last three to six Sprints. Used as the primary input for Sprint capacity planning: velocityAverage determines how many Product Backlog items can realistically be pulled into the next Sprint."@en .

agile:verifiedUnder a owl:ObjectProperty ;
    rdfs:label "verified under"@en ;
    dcterms:source "REDO v2.4.6 Safeguard Framework. http://example.org/reliability#"@en ;
    rdfs:domain owl:Ontology ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range redo:ComplianceGate ;
    skos:definition "Relates this ontology to the REDO compliance gate under which it was verified."@en .

agile:versionString a owl:DatatypeProperty ;
    rdfs:label "version string"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:AgileFramework ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:string ;
    skos:definition "The semantic version identifier of a framework or ontology publication (e.g., '2020' for Scrum Guide, '6.0' for SAFe)."@en .

agile:visualisedBy a owl:ObjectProperty ;
    rdfs:label "visualised by"@en ;
    dcterms:source "Anderson (2010). Kanban. Blue Hole Press."@en ;
    rdfs:domain agile:KanbanMethod ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:KanbanBoard ;
    skos:definition "Relates the KanbanMethod or ProductBacklog to the KanbanBoard that provides visual management of work flow."@en .

agile:wipLimit a owl:DatatypeProperty ;
    rdfs:label "WIP limit"@en ;
    dcterms:source "Anderson, D. (2010). Kanban: Successful Evolutionary Change. Blue Hole Press."@en ;
    rdfs:domain agile:KanbanMethod ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:positiveInteger ;
    skos:definition "The explicit maximum number of work items permitted simultaneously in a Kanban workflow stage, enforcing flow and exposing systemic bottlenecks."@en .

agile:wipLimitValue a owl:DatatypeProperty ;
    rdfs:label "WIP limit value"@en ;
    dcterms:source "Anderson, D.J. (2010). Kanban: Successful Evolutionary Change. Blue Hole Press."@en ;
    rdfs:domain agile:WIPLimit ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:positiveInteger ;
    skos:definition "The maximum number of backlog items or tasks permitted in a workflow stage at any one time. Setting wipLimitValue on a KanbanBoard column enforces the pull policy and triggers the team to collaborate on finishing before starting new work."@en .

agile:workItemAgeHours a owl:DatatypeProperty ;
    rdfs:label "work item age hours"@en ;
    dcterms:source "Vacanti, D. (2015). Actionable Agile Metrics for Predictability."@en ;
    rdfs:domain agile:WorkItemAge ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:decimal ;
    skos:definition "The elapsed time in hours since the current non-finished backlog item entered the In Progress state, used to identify stuck items before they are formally blocked."@en .

agile:yearsExperience a owl:DatatypeProperty ;
    rdfs:label "years experience"@en ;
    dcterms:source "PMI (2021). PMBOK Guide 7th Edition."@en ;
    rdfs:domain agile:TeamMember ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "The number of years of professional experience a TeamMember has in their primary functional role, used for capacity planning and skill matrix analysis."@en .

agile:AgileCoach a owl:Class ;
    rdfs:label "Agile Coach"@en ;
    dcterms:source "Spayd, M. and Adkins, L. (2011). Coaching Agile Teams. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileRole,
        core:Role ;
    skos:definition "An experienced practitioner who helps individuals, teams, and organisations adopt and improve Agile mindsets, practices, and frameworks. An Agile Coach operates at team, programme, and enterprise levels, providing coaching, mentoring, facilitation, and training beyond the scope of the Scrum Master role."@en .

agile:AgilePMTool a owl:Class ;
    rdfs:label "Agile PM Tool"@en ;
    dcterms:source "Atlassian (2024). Jira Software. https://www.atlassian.com/software/jira"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AIAugmentedPM ;
    skos:closeMatch schema:SoftwareApplication ;
    skos:definition """A software platform supporting agile project management
        activities including backlog management, Sprint tracking, Kanban
        visualisation, and reporting (e.g., Jira, Azure DevOps, GitHub Projects)."""@en .

agile:AgileReleaseTrainConcept a owl:Class ;
    rdfs:label "Agile Release Train"@en ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScaledAgileFramework ;
    skos:definition """In SAFe, a long-lived team of agile teams (50-125 people)
        that plans, commits to, and executes together in Program Increments,
        aligned to a common mission and governed by the ART Backlog."""@en .

agile:Architect a owl:Class ;
    rdfs:label "Architect"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:comment "Bridge candidate for TeamTopologies:SystemArchitect — closely aligned with SAFe System Architect."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:TeamMember ;
    skos:definition "A functional role responsible for defining high-level system structure, technology decisions, and Architectural Runway. In SAFe, the System Architect participates in PI Planning and owns Architectural Enablers. In Scrum, architecture emerges from the team with the Architect acting as a facilitating rather than commanding role."@en .

agile:BurndownChart a owl:Class ;
    rdfs:label "Burndown Chart"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileArtefact,
        agile:AgileMetric ;
    skos:definition "A graphical Sprint artefact plotting remaining work (in story points or task hours) on the Y-axis against time (Sprint days) on the X-axis. The chart provides transparency into Sprint progress and signals whether the team is on track to achieve the Sprint Goal."@en,
        """A graphical representation of remaining work (story points
        or hours) plotted against remaining time within a Sprint, providing
        real-time visual indication of whether the team is on track to meet
        the Sprint Goal."""@en .

agile:BurnupChart a owl:Class ;
    rdfs:label "Burn-up Chart"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileArtefact ;
    skos:definition "A graphical artefact plotting completed work against the total scope of work over time. Unlike the Burndown Chart, the Burn-up Chart makes scope changes visible as a rising or falling total-scope line, making it preferred for Product Goal and release tracking."@en .

agile:ComplianceEnabler a owl:Class ;
    rdfs:label "Compliance Enabler"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0: Enablers. https://framework.scaledagile.com/enablers/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Enabler ;
    skos:definition """A SAFe Enabler subtype covering regulatory, audit, legal, or certification
        groundwork that must be completed before a feature or solution can be
        released. Compliance Enablers may become Non-Functional Requirements
        constraining future development."""@en .

agile:DORAMetric a owl:Class ;
    rdfs:label "DORA Metric"@en ;
    dcterms:source "Forsgren, N., Humble, J. and Kim, G. (2018). Accelerate: The Science of Lean Software and DevOps. IT Revolution Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:definition """One of the four empirically validated DevOps Research and
        Assessment metrics — Deployment Frequency, Lead Time for Changes,
        Change Failure Rate, Mean Time to Restore — measuring software delivery
        and operational performance."""@en .

agile:DefinitionOfReady a owl:Class ;
    rdfs:label "Definition of Ready"@en ;
    dcterms:source "Gottesdiener, E. (2011). The Software Requirements Memory Jogger. Goal/QPC."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:hasReadyCondition ;
            owl:someValuesFrom agile:ReadyCondition ],
        agile:AgileArtefact,
        agile:Definition ;
    skos:closeMatch qc:QualityGate ;
    skos:definition """The formal description of the state a backlog item must reach before
        it may be selected into a Sprint. The DoR is the entry gate complementary to
        the Definition of Done and typically includes INVEST criteria, acceptance
        criteria written, estimated, and dependencies identified."""@en .

agile:DevelopmentTeam a owl:Class ;
    rdfs:label "Development Team"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2017). The Scrum Guide (2017 version). https://scrumguides.org/"@en ;
    rdfs:comment "Bridge candidate — owl:equivalentClass agile:Developer per Scrum Guide 2020 renaming."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileRole ;
    owl:equivalentClass agile:Developer ;
    skos:definition "The collective of all Developers on a Scrum Team who collectively create a usable Increment each Sprint. The term 'Development Team' was used in the 2017 Scrum Guide and replaced by 'Developers' in the 2020 Scrum Guide; retained here as a backward-compatibility class for tooling alignment."@en .

agile:ExplorationEnabler a owl:Class ;
    rdfs:label "Exploration Enabler"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0: Enablers. https://framework.scaledagile.com/enablers/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Enabler ;
    skos:definition """A SAFe Enabler subtype supporting research, customer discovery, and
        prototyping activities needed to understand customer needs and evaluate
        alternative solution approaches before committing to implementation."""@en .

agile:ExtremeProgramming a owl:Class ;
    rdfs:label "Extreme Programming (XP)"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained: Embrace Change. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition """An agile framework introduced by Kent Beck emphasising
        engineering practices including Pair Programming, Test-Driven Development,
        Continuous Integration, Refactoring, and Small Releases, grounded in
        five values: communication, simplicity, feedback, courage, and respect."""@en .

agile:LargeScaleScrum a owl:Class ;
    rdfs:label "Large-Scale Scrum (LeSS)"@en ;
    dcterms:source "Larman, C. and Vodde, B. (2016). Large-Scale Scrum: More with LeSS. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://less.works/> ;
    rdfs:subClassOf agile:ScalingFramework ;
    skos:definition """A minimalist Scrum scaling framework by Craig Larman and Bas
        Vodde in which multiple Scrum Teams share a single Product Backlog,
        a single Product Owner, and a common Sprint cadence, emphasising
        whole-product focus over coordination overhead."""@en .

agile:LeadTime a owl:Class ;
    rdfs:label "Lead Time"@en ;
    dcterms:source "Anderson, D.J. (2010). Kanban: Successful Evolutionary Change for Your Technology Business. Blue Hole Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:definition "The elapsed time from when a customer request enters the system (added to backlog) until it is delivered. Distinct from Cycle Time, which starts when active work begins. Per Little's Law: Lead Time = WIP / Throughput. A key customer-facing delivery metric."@en .

agile:LeanSoftwareDevelopment a owl:Class ;
    rdfs:label "Lean Software Development"@en ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development: An Agile Toolkit. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition """The application of Lean Manufacturing's seven waste-elimination
        principles to software development, as articulated by Mary and Tom
        Poppendieck: eliminate waste, build quality in, create knowledge,
        defer commitment, deliver fast, respect people, optimise the whole."""@en .

agile:ManifestoPrinciple4 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 4: Business-Dev Collaboration"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Business people and developers must work together daily throughout the project."@en .

agile:ManifestoValue_CustomerCollaborationOverNegotiation a agile:ManifestoValue,
        owl:NamedIndividual ;
    rdfs:label "Customer Collaboration over Contract Negotiation"@en ;
    agile:manifestoOrder 3 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The third Agile Manifesto value asserting that an ongoing collaborative relationship with the customer throughout delivery produces better outcomes than adversarial, contract-enforced interactions."@en .

agile:ManifestoValue_ResponseToChangeOverPlan a agile:ManifestoValueClass,
        owl:NamedIndividual ;
    rdfs:label "Responding to Change over Following a Plan"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "We value responding to change over following a plan. Plans are useful; the ability to adapt is essential."@en .

agile:NonFunctionalRequirement a owl:Class ;
    rdfs:label "Non-Functional Requirement"@en ;
    dcterms:source "ISO/IEC 25010:2011. Systems and Software Quality Requirements and Evaluation (SQuaRE)."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://www.iso.org/standard/35733.html> ;
    rdfs:subClassOf agile:Requirement ;
    skos:closeMatch qc:Reliability ;
    skos:definition """A persistent quality attribute or constraint that applies globally to
        the system or all items in the backlog: performance, security, availability,
        scalability, usability. NFRs constrain rather than extend the solution and
        may not appear as individual backlog items."""@en .

agile:ProductGoal a agile:Commitment,
        owl:NamedIndividual ;
    rdfs:label "Product Goal"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The Product Backlog's commitment: the long-term objective for the Scrum Team describing a future state of the product as a planning target."@en .

agile:ProductRoadmap a owl:Class ;
    rdfs:label "Product Roadmap"@en ;
    dcterms:source "Pichler, R. (2016). Strategize: Product Strategy and Product Roadmap Practices. Pichler Consulting."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:manages ;
            owl:someValuesFrom agile:Release ],
        agile:AgileArtefact ;
    skos:definition """A strategic planning artefact communicating planned deliverables,
        milestones, and release timelines over a future horizon, maintained by the
        Product Owner and updated as the Product Goal and market conditions evolve.
        A Roadmap is not a commitment but a forecast subject to agile adaptation."""@en .

agile:Scrumban a owl:Class ;
    rdfs:label "Scrumban"@en ;
    dcterms:source "Kniberg, H. and Skarin, M. (2010). Kanban and Scrum: Making the Most of Both. InfoQ. https://www.infoq.com/minibooks/kanban-scrum-minibook/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition """A hybrid agile methodology combining Scrum's Sprint cadence
        and event structure with Kanban's WIP limits and flow visualisation,
        introduced by Corey Ladas as a transitional approach for teams moving
        from project-based to product-based delivery."""@en .

agile:ServantLeadership a owl:Class ;
    rdfs:label "Servant Leadership"@en ;
    dcterms:source "Greenleaf, R.K. (1977). Servant Leadership. Paulist Press.; Schwaber & Sutherland (2020). Scrum Guide."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition "A leadership philosophy in which the leader's primary role is to serve the team by removing impediments, enabling self-organisation, protecting the team from interference, and facilitating rather than directing. Servant leadership is the defining characteristic of the Scrum Master role per the Scrum Guide 2020."@en .

agile:SprintRetrospective a owl:Class ;
    rdfs:label "Sprint Retrospective"@en ;
    agile:facilitatedBy agile:ScrumMaster ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScrumEvent ;
    skos:definition """The event following the Sprint Review in which the Scrum Team
        inspects itself with respect to people, relationships, process, and tools,
        and creates a plan for implementing improvements in the next Sprint.
        Maximum 3 hours for a one-month Sprint."""@en .

agile:State_Approved a agile:BacklogItemState,
        owl:NamedIndividual ;
    rdfs:label "Approved"@en ;
    agile:transitionsTo agile:State_Ready ;
    dcterms:source "Microsoft (2024). Azure DevOps Scrum process. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:comment "Lifecycle transition: Approved → Ready"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State used in tool-based Scrum workflows (Azure DevOps, Jira) indicating a backlog item that has been described and prioritised by the Product Owner but not yet committed to a Sprint. Sits between Refined and Ready in some tool implementations."@en .

agile:State_Blocked a agile:BacklogItemState,
        owl:NamedIndividual ;
    rdfs:label "Blocked"@en ;
    agile:transitionsTo agile:State_InProgress ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0. https://framework.scaledagile.com/"@en ;
    rdfs:comment "Lifecycle transition: Blocked → InProgress"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State of a backlog item that cannot progress because an Impediment outside the team's control is preventing work. A blocked item remains In Progress in the Scrum board but is flagged for Scrum Master escalation."@en .

agile:State_InReview a agile:BacklogItemState,
        owl:NamedIndividual ;
    rdfs:label "In Review"@en ;
    agile:transitionsTo agile:State_Done ;
    dcterms:source "Atlassian (2024). Jira Software Scrum workflow. https://support.atlassian.com/jira-software-cloud/"@en ;
    rdfs:comment "Lifecycle transition: InReview → Done"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Sub-state of InProgress in which the implemented work is under peer review, QA testing, or Product Owner acceptance testing before transitioning to Done. Used in Kanban-style boards and Pull-Request driven workflows."@en .

agile:State_Ready a agile:BacklogItemState,
        owl:NamedIndividual ;
    rdfs:label "Ready"@en ;
    agile:transitionsTo agile:State_Cancelled,
        agile:State_InProgress ;
    dcterms:source "Gottesdiener, E. (2011). The Software Requirements Memory Jogger. Goal/QPC."@en ;
    rdfs:comment "Lifecycle transition: Ready → Cancelled"@en,
        "Lifecycle transition: Ready → InProgress"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State of a backlog item satisfying the Definition of Ready: estimated, acceptance criteria written, dependencies resolved, eligible for Sprint Planning."@en .

agile:State_Refined a agile:BacklogItemState,
        owl:NamedIndividual ;
    rdfs:label "Refined"@en ;
    agile:transitionsTo agile:State_Approved ;
    dcterms:source "Gottesdiener, E. (2011). The Software Requirements Memory Jogger. Goal/QPC."@en ;
    rdfs:comment "Lifecycle transition: Refined → Approved"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State of a backlog item that has been elaborated with acceptance criteria and estimated but not yet declared Ready for Sprint Planning."@en .

agile:Tester a owl:Class ;
    rdfs:label "Tester"@en ;
    dcterms:source "ISTQB (2023). ISTQB Glossary v4.3. https://glossary.istqb.org/"@en ;
    rdfs:comment "Bridge candidate for ISTQB Tester role — skos:closeMatch dbpedia:Software_tester."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:TeamMember ;
    skos:closeMatch <http://dbpedia.org/resource/Software_tester>,
        <http://dbpedia.org/resource/Software_testing> ;
    skos:definition "A functional role responsible for designing and executing test cases, verifying acceptance criteria, identifying defects, and validating that the Increment meets quality standards. In BDD teams, testers collaborate with developers and analysts to write Gherkin scenarios."@en .

agile:Theme a owl:Class ;
    rdfs:label "Theme"@en ;
    dcterms:source "Leffingwell, D. (2011). Agile Software Requirements. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:decomposesInto ;
            owl:someValuesFrom agile:Epic ],
        agile:BacklogItem ;
    skos:definition """A high-level strategic grouping of related Epics directed toward a shared
        business objective, used in portfolio and programme backlogs to provide
        thematic coherence and enable cross-Epic dependency management."""@en .

agile:Throughput a owl:Class ;
    rdfs:label "Throughput"@en ;
    dcterms:source "Anderson, D.J. (2010). Kanban: Successful Evolutionary Change for Your Technology Business. Blue Hole Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:closeMatch <http://schema.org/ItemList> ;
    skos:definition "The number of backlog items completed by a team within a defined time period (e.g., items per week). Throughput is the Kanban equivalent of Velocity and follows Little's Law: Throughput = WIP / Cycle Time. It is the primary metric for forecasting delivery in flow-based systems."@en .

agile:UIDesigner a owl:Class ;
    rdfs:label "UI Designer"@en ;
    dcterms:source "Nielsen Norman Group (2023). UX Careers Report. https://www.nngroup.com/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:TeamMember ;
    skos:definition "A functional role responsible for visual and interaction design of the user interface, producing wireframes, prototypes, and design specifications that feed User Story acceptance criteria. Also called UX Designer or Product Designer in different organisational contexts."@en .

agile:ValueStream a owl:Class ;
    rdfs:label "Value Stream"@en ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide. Addison-Wesley. https://framework.scaledagile.com/value-stream/"@en ;
    rdfs:comment "Bridge candidate for SAFe PortfolioBacklog chapter"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:closeMatch <http://purl.org/NET/ceo#ValueStream> ;
    skos:definition "In SAFe, the sequence of steps an organisation uses to build solutions that provide a continuous flow of value to a customer. Development Value Streams define how software-intensive systems are developed; Operational Value Streams define how they are operated to serve end customers."@en .

agile:Velocity a owl:Class ;
    rdfs:label "Velocity"@en ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:definition """The empirical measure of the amount of work (in story points
        or items) a Scrum Team completes during a single Sprint, used for
        Sprint planning and release forecasting. Not an externally imposed
        performance target."""@en .

agile:VelocityMetric a owl:Class ;
    rdfs:label "Velocity"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:definition "The sum of story points (or other estimation units) for all backlog items completed in a Sprint. Velocity is a historical average used for Sprint capacity forecasting; it is not a performance target and should not be used for cross-team comparison per the Scrum Guide."@en .

agile:WorkItemAge a owl:Class ;
    rdfs:label "Work Item Age"@en ;
    dcterms:source "Vacanti, D. (2015). Actionable Agile Metrics for Predictability. ActionableAgile Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:definition "A leading Kanban flow metric measuring the elapsed time between when a work item started and the current moment, applied only to non-finished items. Complements Cycle Time (which measures finished items) by providing transparency into items that are 'stuck' even if not formally blocked."@en .

agile:XPFrameworkInd a agile:ExtremeProgramming,
        owl:NamedIndividual ;
    rdfs:label "Extreme Programming (Beck 1999)"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "XP as defined by Kent Beck in 1999: five values, thirteen primary and corollary practices centred on engineering discipline and customer collaboration."@en .

agile:answerableBy a owl:ObjectProperty ;
    rdfs:label "answerable by"@en ;
    dcterms:source "Gruber, T.R. (1993). A translation approach to portable ontology specifications. Knowledge Acquisition, 5(2)."@en ;
    rdfs:domain core:CompetencyQuestion ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range owl:Class ;
    skos:definition "Relates a competency question to the ontology class or property that provides the information needed to answer it via SPARQL query."@en .

agile:blockedBy a owl:ObjectProperty ;
    rdfs:label "blocked by"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:Impediment ;
    skos:definition "Relates a BacklogItem or Task in State_Blocked to the Impediment causing the blockage. The Scrum Master uses this relation to prioritise impediment removal and track root-cause patterns across sprints."@en .

agile:derivedFrom a owl:ObjectProperty ;
    rdfs:label "derived from"@en ;
    dcterms:source "Agile Alliance (2020). Glossary: Given-When-Then. https://www.agilealliance.org/glossary/given-when-then/"@en ;
    rdfs:domain agile:AcceptanceTest ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:GherkinScenario ;
    rdfs:subPropertyOf core:derivedFrom ;
    skos:definition "Relates an acceptance test to the Gherkin scenario from which it was generated."@en .

agile:facilitates a owl:ObjectProperty ;
    rdfs:label "facilitates"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ScrumMaster ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ScrumEvent ;
    skos:definition "Relates the Scrum Master to the Scrum events they are responsible for facilitating to ensure the team derives maximum value."@en .

agile:givenContext a owl:DatatypeProperty ;
    rdfs:label "given context"@en ;
    dcterms:source "Agile Alliance (2020). Glossary: Given-When-Then. https://www.agilealliance.org/glossary/given-when-then/"@en ;
    rdfs:domain agile:GherkinScenario ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:string ;
    skos:definition "The 'Given' precondition clause of a Gherkin scenario, specifying the initial context or system state before the action."@en .

agile:hasReadyCondition a owl:ObjectProperty ;
    rdfs:label "has ready condition"@en ;
    dcterms:source "Gottesdiener, E. (2011). The Software Requirements Memory Jogger. Goal/QPC."@en ;
    rdfs:domain agile:DefinitionOfReady ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ReadyCondition ;
    skos:definition "Relates a Definition of Ready to its individual conditions, each of which must be satisfied before a backlog item may enter Sprint Planning."@en .

agile:hasRole a owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:TeamMember ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileRole ;
    skos:definition "Relates a TeamMember to their AgileRole classification within the team, allowing a single person to hold multiple functional roles (e.g., a Developer who also acts as Tester)."@en .

agile:hasTaskStatus a owl:ObjectProperty ;
    rdfs:label "has task status"@en ;
    dcterms:source "Microsoft (2024). Azure DevOps Scrum process. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:domain agile:Task ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:TaskStatus ;
    skos:definition "Relates a Task to its current TaskStatus, providing finer-grained lifecycle tracking within the Sprint compared to the parent BacklogItem's hasState."@en .

agile:isTimebox a owl:DatatypeProperty ;
    rdfs:label "is timebox"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained. Addison-Wesley."@en ;
    rdfs:domain agile:Spike ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether the Spike has a fixed time box; Spikes should always be true — unconstrained Spikes violate agile principles."@en .

agile:manifestoOrder a owl:DatatypeProperty ;
    rdfs:label "manifesto order"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:domain agile:ManifestoValue ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:positiveInteger ;
    skos:definition "The ordinal position (1-4) of a Manifesto Value in the original Agile Manifesto publication."@en .

agile:principleNumber a owl:DatatypeProperty ;
    rdfs:label "principle number"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/principles.html"@en ;
    rdfs:domain agile:AgilePrinciple ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:positiveInteger ;
    skos:definition "The ordinal position (1-12) of an Agile Principle in the Agile Manifesto's twelve principles."@en .

agile:produces a owl:ObjectProperty ;
    rdfs:label "produces"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ScrumEvent ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileArtefact ;
    skos:definition "Relates a Scrum event to an artefact it produces as output; e.g., Sprint Planning produces the Sprint Backlog."@en .

agile:producesIncrement a owl:ObjectProperty ;
    rdfs:label "produces increment"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:Sprint ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductIncrement ;
    skos:definition "Relates a Sprint to the Product Increment that must be produced by the end of the Sprint to a Done, usable, and releasable standard."@en .

agile:satisfiedBy a owl:ObjectProperty ;
    rdfs:label "satisfied by"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:DefinitionOfDone ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductIncrement ;
    skos:definition "Relates the DefinitionOfDone to the ProductIncrement that has met all its exit criteria. An Increment that satisfies the DoD is releasable. This property provides the formal quality gate that links the team's quality agreement to the actual delivered output."@en .

agile:storyPointValue a owl:DatatypeProperty ;
    rdfs:label "story point value"@en ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "The relative effort estimate assigned to a backlog item using story points, typically from the Fibonacci scale."@en .

agile:thenOutcome a owl:DatatypeProperty ;
    rdfs:label "then outcome"@en ;
    dcterms:source "Agile Alliance (2020). Glossary: Given-When-Then. https://www.agilealliance.org/glossary/given-when-then/"@en ;
    rdfs:domain agile:GherkinScenario ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:string ;
    skos:definition "The 'Then' expected-result clause of a Gherkin scenario, specifying the observable consequences that should follow the triggering action."@en .

agile:whenAction a owl:DatatypeProperty ;
    rdfs:label "when action"@en ;
    dcterms:source "Agile Alliance (2020). Glossary: Given-When-Then. https://www.agilealliance.org/glossary/given-when-then/"@en ;
    rdfs:domain agile:GherkinScenario ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range xsd:string ;
    skos:definition "The 'When' trigger clause of a Gherkin scenario, specifying the action or event that initiates the behaviour being specified."@en .

<http://example.org/agile/patch/v1.1.0> a owl:Ontology ;
    rdfs:label "Ontology4Agile Patch v1.1.0 — Backlog Item Taxonomy, Requirements, Grooming, Non-SDLC"@en ;
    dcterms:created "2026-03-06"^^xsd:date ;
    dcterms:creator "Yusuf Altunel, PhD — Istanbul Kültür University"@en ;
    dcterms:description """Patch extending Ontology4Agile v1.0.0 with 34 concepts identified
        by systematic literature and industrial practice survey:
        (1) Complete PBI type taxonomy: Theme→Epic→Feature→UserStory/Enabler/Spike/Defect/Bug/TechnicalDebt/Refactor;
        (2) Requirement types: Requirement, FunctionalRequirement, NonFunctionalRequirement, BusinessRule, Constraint, Expectation;
        (3) Grooming/readiness apparatus: DefinitionOfReady, INVESTCriteria, ReadyCondition, GherkinScenario, BehaviorDrivenDevelopment, RefinementActivity;
        (4) Non-SDLC work items: NonSDLCBacklogItem, OperationalTask, ComplianceItem;
        (5) PBI lifecycle: BacklogItemState, MoSCoWPriority;
        (6) Release planning: ProductRoadmap, ProgramIncrement, Release;
        (7) Acceptance testing: AcceptanceTest, GherkinScenario;
        (8) SAFe Capability level: Capability."""@en ;
    dcterms:source <https://framework.scaledagile.com/glossary>,
        <https://www.iso.org/standard/72089.html>,
        <https://www.scrum.org/resources/product-backlog-items> ;
    dcterms:title "Ontology4Agile Patch v1.1.0"@en ;
    owl:imports <http://example.org/agile> ;
    owl:priorVersion <http://example.org/agile/v1.0.0> ;
    owl:versionIRI <http://example.org/agile/patch/v1.1.0> ;
    owl:versionInfo "1.1.0" .

agile:AIAugmentedPM a owl:Class ;
    rdfs:label "AI-Augmented Project Management"@en ;
    dcterms:source "Tawosi, V. et al. (2022). Agile effort estimation. IEEE Transactions on Software Engineering, 49(4)."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition """The use of Artificial Intelligence (AI) and Natural Language
        Processing (NLP) techniques to enhance agile project management tasks
        including automated user story generation, story point estimation,
        defect prediction, and retrospective analysis."""@en .

agile:AcceptanceTest a owl:Class ;
    rdfs:label "Acceptance Test"@en ;
    dcterms:source "Agile Alliance (2020). Glossary: Acceptance Testing. https://www.agilealliance.org/glossary/acceptance/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:derivedFrom ;
            owl:someValuesFrom agile:GherkinScenario ],
        agile:AgilePractice ;
    skos:definition """An automated or manual test derived from a GherkinScenario or acceptance
        criterion that verifies a backlog item meets its specified behaviour before
        it can be considered Done. Acceptance tests may be specified using ATDD
        (Acceptance Test-Driven Development) or BDD tools such as Cucumber."""@en .

agile:ContinuousIntegrationPractice a owl:Class ;
    rdfs:label "Continuous Integration"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:XPPractice ;
    owl:equivalentClass meta:ContinuousIntegration ;
    skos:definition """The XP practice of integrating and testing code changes
        multiple times per day, enabling early detection of integration defects
        and reducing merge complexity."""@en .

agile:CrossFunctionalTeam a owl:Class ;
    rdfs:label "Cross-Functional Team"@en ;
    dcterms:source "Beck, K. et al. (2001). Agile Manifesto. https://agilemanifesto.org/; Schwaber & Sutherland (2020). Scrum Guide."@en ;
    rdfs:comment "Bridge candidate for TeamTopologies:StreamAlignedTeam — cross-functional self-organizing teams share key attributes."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileRole,
        core:Team ;
    skos:definition "A team whose members collectively possess all skills necessary to complete work without external dependency: typically design, analysis, development, testing, and operations capabilities. Cross-functionality is a core Agile Manifesto principle and a defining attribute of the Scrum Team."@en .

agile:Definition a owl:Class ;
    rdfs:label "Definition"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileArtefact ;
    skos:definition "An abstract parent class for formal team agreements that specify entry or exit criteria for a workflow stage. Concrete subclasses include DefinitionOfReady (entry gate for Sprint Planning) and DefinitionOfDone (exit gate for declaring work complete). Definitions are team-owned, version-controlled artefacts."@en .

agile:Developer a owl:Class ;
    rdfs:label "Developer (Scrum)"@en ;
    agile:upholds agile:ManifestoPrinciple8,
        agile:ManifestoPrinciple9 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScrumRole,
        core:Developer ;
    skos:definition """A cross-functional professional within the Scrum Team who
        executes sprint work to meet Sprint Goals, self-organises collaboratively,
        and is collectively accountable for delivering a Done, usable Increment
        each Sprint."""@en .

agile:INVESTCriteria a owl:Class ;
    rdfs:label "INVEST Criteria"@en ;
    dcterms:source "Wake, B. (2003). INVEST in Good Stories, and SMART Tasks. https://xp123.com/articles/invest-in-good-stories-and-smart-tasks/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://xp123.com/articles/invest-in-good-stories-and-smart-tasks/> ;
    rdfs:subClassOf agile:AgileArtefact ;
    skos:definition """Six quality criteria for well-formed User Stories: Independent (not
        dependent on other stories), Negotiable (scope is not fixed), Valuable
        (delivers business value), Estimable (team can size it), Small (fits within
        a Sprint), Testable (acceptance criteria can be written)."""@en .

agile:ImprovementAction a owl:Class ;
    rdfs:label "Improvement Action"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0 Iteration Retrospective. https://framework.scaledagile.com/iteration-retrospective/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:closeMatch qc:Improvement ;
    skos:definition "A concrete, time-boxed action item identified during a Sprint Retrospective to improve the team's process, tools, interactions, or Definition of Done. Improvement Actions are added to the Sprint Backlog and treated as first-class deliverables for the next Sprint."@en .

agile:ManifestoPrinciple8 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 8: Sustainable Pace"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Agile processes promote sustainable development. The sponsors, developers, and users should be able to maintain a constant pace indefinitely."@en .

agile:ManifestoPrinciple9 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 9: Technical Excellence"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Continuous attention to technical excellence and good design enhances agility."@en .

agile:ManifestoValueClass a owl:Class ;
    rdfs:label "Manifesto Value"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileManifestoValue ;
    skos:definition "The class of the four Manifesto Values (2001) that express the fundamental trade-off preferences in Agile thinking: Individuals over processes, Working software over documentation, Customer collaboration over negotiation, Responding to change over following a plan."@en ;
    skos:exactMatch <http://agilemanifesto.org/>,
        <https://agilemanifesto.org/> .

agile:ManifestoValue_WorkingSoftwareOverDocumentation a agile:ManifestoValue,
        owl:NamedIndividual ;
    rdfs:label "Working Software over Comprehensive Documentation"@en ;
    agile:manifestoOrder 2 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The second Agile Manifesto value asserting that a functioning product increment provides more reliable evidence of progress and more actionable feedback than any written specification, however thorough."@en .

agile:ReadyCondition a owl:Class ;
    rdfs:label "Ready Condition"@en ;
    dcterms:source "Gottesdiener, E. (2011). The Software Requirements Memory Jogger. Goal/QPC."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileArtefact ;
    skos:definition """An individual condition in a Definition of Ready that a backlog item
        must satisfy before being selected into Sprint Planning, such as 'acceptance
        criteria written', 'estimated in story points', or 'dependencies identified'."""@en .

agile:ScrumFramework a owl:Class ;
    rdfs:label "Scrum Framework"@en ;
    agile:manifestoSource agile:AgileManifesto ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. Scrum.org. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://scrumguides.org/> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition """A lightweight agile framework for developing and sustaining
        complex products, defined by three roles (Product Owner, Scrum Master,
        Developers), five events (Sprint, Sprint Planning, Daily Scrum,
        Sprint Review, Sprint Retrospective), and three artefacts
        (Product Backlog, Sprint Backlog, Increment), operating within
        time-boxed Sprints."""@en .

agile:Spike a owl:Class ;
    rdfs:label "Spike"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained: Embrace Change. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogItem ;
    skos:definition """A time-boxed investigation or research backlog item used to reduce
        uncertainty about how a Feature or Story can be delivered, or to explore
        a technical approach. A Spike produces knowledge (a document, prototype,
        or decision) rather than a shippable increment."""@en ;
    skos:narrower agile:ExplorationEnabler .

agile:State_Cancelled a agile:BacklogItemState,
        owl:NamedIndividual ;
    rdfs:label "Cancelled"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Terminal state of a backlog item removed from the Product Backlog by the Product Owner because it no longer contributes to the Product Goal. Distinct from Done: no work was completed to remove the item."@en .

agile:State_Done a agile:BacklogItemState,
        owl:NamedIndividual ;
    rdfs:label "Done"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Terminal state of a backlog item satisfying the Definition of Done: implemented, tested, and meeting all quality criteria for the Increment."@en .

agile:State_InProgress a agile:BacklogItemState,
        owl:NamedIndividual ;
    rdfs:label "In Progress"@en ;
    agile:transitionsTo agile:State_Blocked,
        agile:State_Done,
        agile:State_InReview ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:comment "Lifecycle transition: InProgress → Blocked"@en,
        "Lifecycle transition: InProgress → Done"@en,
        "Lifecycle transition: InProgress → InReview"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "State of a backlog item currently being developed within an active Sprint."@en .

agile:WIPLimit a owl:Class ;
    rdfs:label "WIP Limit"@en ;
    dcterms:source "Anderson, D.J. (2010). Kanban: Successful Evolutionary Change. Blue Hole Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileMetric ;
    skos:definition "A policy constraint on the maximum number of backlog items or tasks allowed in a given workflow state simultaneously. WIP limits enforce pull-based flow and are the primary mechanism through which Kanban prevents overloading and reduces cycle time."@en .

agile:belongsToFramework a owl:ObjectProperty ;
    rdfs:label "belongs to framework"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained. Addison-Wesley."@en ;
    rdfs:domain agile:AgilePractice ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileFramework ;
    skos:definition "Relates an agile practice to the framework that defines or prescribes it."@en .

agile:composedOf a owl:ObjectProperty ;
    rdfs:label "composed of"@en ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide. Addison-Wesley."@en ;
    rdfs:domain agile:ProgramIncrement ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:Sprint ;
    skos:definition "Relates a Program Increment or Release to the Sprints or Increments it is composed of."@en .

agile:hasAcceptanceCriteria a owl:ObjectProperty ;
    rdfs:label "has acceptance criteria"@en ;
    dcterms:source "Cohn, M. (2004). User Stories Applied. Addison-Wesley."@en ;
    rdfs:domain agile:BacklogItem ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AcceptanceCriteria ;
    skos:definition "Relates a backlog item to its acceptance criteria, the set of conditions that define when the item is complete and acceptable for delivery."@en .

agile:hasTeamMember a owl:ObjectProperty ;
    rdfs:label "has team member"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ScrumTeam ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:AgileRole ;
    skos:definition "Relates a Scrum Team to the role-holding individuals who collectively comprise it."@en .

agile:manages a owl:ObjectProperty ;
    rdfs:label "manages"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ProductOwner ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:ProductBacklog ;
    skos:definition "Relates the Product Owner to the Product Backlog for which they hold sole ordering and prioritisation authority."@en .

agile:BacklogRefinement a owl:Class ;
    rdfs:label "Backlog Refinement"@en ;
    agile:facilitatedBy agile:ProductOwner ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScrumEvent ;
    skos:definition """The ongoing activity in which the Product Owner and Scrum Team
        collaboratively review, decompose, estimate, and reprioritise Product
        Backlog items to ensure they are ready for upcoming Sprint Planning events.
        Also called backlog grooming, pre-planning, or story time."""@en .

agile:Epic a owl:Class ;
    rdfs:label "Epic"@en ;
    dcterms:source "Cohn, M. (2004). User Stories Applied. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:decomposesInto ;
            owl:someValuesFrom agile:UserStory ],
        agile:BacklogItem ;
    skos:definition """A large chunk of work with a single common objective —
        a feature, customer request, or business requirement — that is too
        large to be completed within a single Sprint and is decomposed into
        Features and User Stories."""@en .

agile:KanbanBoard a owl:Class ;
    rdfs:label "Kanban Board"@en ;
    dcterms:source "Anderson, D.J. (2010). Kanban. Blue Hole Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileArtefact ;
    skos:definition "A visual management artefact representing the team's workflow as columns corresponding to work states (e.g., To Do, In Progress, Done). Each backlog item is represented as a card moving across columns. WIP limits constrain the number of cards allowed in each column at any time."@en .

agile:ManifestoPrinciple1 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 1: Satisfy the Customer"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Our highest priority is to satisfy the customer through early and continuous delivery of valuable software."@en .

agile:ManifestoPrinciple11 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 11: Self-Organising Teams"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The best architectures, requirements, and designs emerge from self-organising teams."@en .

agile:ManifestoPrinciple12 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 12: Regular Reflection"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "At regular intervals, the team reflects on how to become more effective, then tunes and adjusts its behaviour accordingly."@en .

agile:ManifestoPrinciple3 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 3: Deliver Frequently"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Deliver working software frequently, from a couple of weeks to a couple of months, with a preference to the shorter timescale."@en .

agile:ManifestoPrinciple5 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 5: Motivated Individuals"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Build projects around motivated individuals. Give them the environment and support they need, and trust them to get the job done."@en .

agile:ManifestoValue_IndividualsOverProcesses a agile:ManifestoValue,
        owl:NamedIndividual ;
    rdfs:label "Individuals and Interactions over Processes and Tools"@en ;
    agile:manifestoOrder 1 ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The first Agile Manifesto value asserting that while processes and tools have value, the quality of human collaboration and communication are more important determinants of software project success."@en .

agile:ProductRoadmapState a owl:Class ;
    rdfs:label "Product Roadmap State"@en ;
    dcterms:source "Pichler, R. (2016). Strategize. Pichler Consulting."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ArtefactState ;
    skos:definition "The publication state of a Product Roadmap: Draft (internal working version), Published (shared with stakeholders), Archived (superseded by a newer version). Roadmap state governs stakeholder communication and version control."@en .

agile:ProductVision a owl:Class ;
    rdfs:label "Product Vision"@en ;
    dcterms:source "Pichler, R. (2016). Strategize. Pichler Consulting.; SAFe 6.0 Vision. https://framework.scaledagile.com/vision/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileArtefact ;
    skos:definition "A short, inspiring statement describing the future state of the product, who it serves, and why it matters. The Product Vision is the highest-level strategic artefact maintained by the Product Owner; it provides the long-term direction from which the Product Goal and Product Backlog are derived."@en .

agile:ScaledAgileFramework a owl:Class ;
    rdfs:label "Scaled Agile Framework (SAFe)"@en ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide: Scaled Agile Framework for Lean Enterprises. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://scaledagileframework.com/> ;
    rdfs:subClassOf agile:ScalingFramework ;
    skos:definition """The most widely adopted enterprise agile scaling framework,
        introducing the Agile Release Train (ART) as a long-lived team of agile
        teams (50-125 people) planning and executing together in Program Increments (PI),
        available in Essential, Large Solution, Portfolio, and Full configurations."""@en .

agile:ScrumTeam a owl:Class ;
    rdfs:label "Scrum Team"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:hasTeamMember ;
            owl:someValuesFrom agile:ProductOwner ],
        [ a owl:Restriction ;
            owl:onProperty agile:hasTeamMember ;
            owl:someValuesFrom agile:ScrumMaster ],
        agile:AgileRole ;
    owl:equivalentClass meta:CrossFunctionalTeam ;
    skos:definition """The cohesive unit of professionals consisting of one
        Product Owner, one Scrum Master, and Developers (3–9 total), collectively
        accountable for creating a valuable, useful Increment every Sprint."""@en .

agile:Enabler a owl:Class ;
    rdfs:label "Enabler"@en ;
    dcterms:source "Scaled Agile Inc. (2023). SAFe 6.0: Enablers. https://framework.scaledagile.com/enablers/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://framework.scaledagile.com/enablers/> ;
    rdfs:subClassOf agile:BacklogItem ;
    skos:definition """A backlog item that extends the Architectural Runway of the solution or
        improves the performance of the development value stream, making future
        business features possible. Enablers are first-class backlog items subject
        to estimation, WIP limits, and result presentation."""@en .

agile:EstimationTechnique a owl:Class ;
    rdfs:label "Estimation Technique"@en ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgilePractice ;
    skos:definition """A method used by agile teams to forecast the size, effort,
        or complexity of backlog items, typically using relative units such as
        story points to avoid false precision and promote team consensus."""@en .

agile:ManifestoPrinciple7 a agile:ManifestoPrincipleClass,
        owl:NamedIndividual ;
    rdfs:label "Principle 7: Working Software is Progress"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "Working software is the primary measure of progress."@en .

agile:NonSDLCBacklogItem a owl:Class ;
    rdfs:label "Non-SDLC Backlog Item"@en ;
    dcterms:source "Scaled Agile Inc. (2023). Team Backlog. SAFe 6.0. https://framework.scaledagile.com/team-backlog/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogItem ;
    skos:definition """A backlog item representing non-software-development work managed in the
        same agile backlog as functional stories: operations, compliance, HR,
        procurement, research, or organisational improvement items. Non-SDLC items
        receive the same prioritisation, estimation, and DoD treatment as software items."""@en .

agile:ProductGoalClass a owl:Class ;
    rdfs:label "Product Goal"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Commitment ;
    skos:definition """The long-term objective for the Scrum Team describing a
        future state of the product that serves as a planning target.
        Only one Product Goal can be in effect at a time."""@en .

agile:ProgramIncrement a owl:Class ;
    rdfs:label "Program Increment"@en ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide. Addison-Wesley. https://scaledagileframework.com/"@en ;
    rdfs:comment "Bridge candidate — skos:closeMatch pm_classic:WorkPackage pending pm_classic chapter"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://framework.scaledagile.com/program-increment/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:composedOf ;
            owl:someValuesFrom agile:Sprint ],
        agile:AgileArtefact ;
    skos:definition """A time-boxed planning and delivery cadence, typically four to six Sprints
        (8-12 weeks), during which an Agile Release Train delivers incremental value
        in the form of a Potentially Shippable Increment. PI Planning synchronises
        all ART teams at the start of each PI."""@en .

agile:SprintGoal a agile:Commitment,
        owl:NamedIndividual ;
    rdfs:label "Sprint Goal"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    skos:definition "The Sprint Backlog's commitment: a short collaborative description of what the Scrum Team plans to achieve during the Sprint, providing coherent intent."@en .

agile:AcceptanceCriteria a owl:Class ;
    rdfs:label "Acceptance Criteria"@en ;
    dcterms:source "Cohn, M. (2004). User Stories Applied. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogItem ;
    skos:closeMatch qc:QualityCriterion ;
    skos:definition """The set of conditions that must be satisfied for a User Story
        or backlog item to be considered complete and acceptable for delivery,
        typically defined by the Product Owner in collaboration with stakeholders."""@en .

agile:AgileEngineeringPractice agile:implementsPrinciple agile:ManifestoPrinciple8,
        agile:ManifestoPrinciple9 .

agile:AgilePractice a owl:Class ;
    rdfs:label "Agile Practice"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained: Embrace Change. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition """A specific, repeatable technique or activity employed within
        agile delivery that embodies one or more Agile Manifesto principles,
        such as pair programming, daily standup, or retrospective facilitation."""@en .

agile:DefinitionOfDone a owl:Class ;
    rdfs:label "Definition of Done"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:Definition,
        agile:ScrumArtefact,
        qc:QualityAssuranceProcess ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( agile:ScrumArtefact qc:QualityAssuranceProcess ) ] ;
    skos:closeMatch qc:QualityGate ;
    skos:definition """The formal description of the state of the Product Increment
        when it meets the quality measures required for the product. Serves as a
        shared understanding of what 'complete' means for every Sprint Increment.
        If a backlog item does not meet the DoD it cannot be released."""@en .

agile:DevOps a owl:Class ;
    rdfs:label "DevOps"@en ;
    dcterms:source "Fitzgerald, B. and Stol, K.-J. (2017). Continuous software engineering. Journal of Systems and Software, 123."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition """A cultural and technical practice integrating software
        development and IT operations to enable Continuous Integration and
        Continuous Delivery (CI/CD) pipelines delivering code from commit to
        production in minutes or hours."""@en .

agile:Feature a owl:Class ;
    rdfs:label "Feature"@en ;
    dcterms:source "Leffingwell, D. (2018). SAFe 4.5 Reference Guide. Addison-Wesley. https://scaledagileframework.com/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://framework.scaledagile.com/features-and-capabilities/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:decomposesInto ;
            owl:someValuesFrom agile:UserStory ],
        [ a owl:Restriction ;
            owl:onProperty agile:hasAcceptanceCriteria ;
            owl:someValuesFrom agile:AcceptanceCriteria ],
        agile:BacklogItem ;
    skos:definition """A service provided by the system that fulfils a stakeholder need,
        deliverable by a single Agile Release Train within one Program Increment.
        Features sit between Epics and User Stories in the SAFe backlog hierarchy
        and include a short phrase, a benefit hypothesis, and acceptance criteria."""@en .

agile:KanbanMethod a owl:Class ;
    rdfs:label "Kanban Method"@en ;
    agile:manifestoSource agile:AgileManifesto ;
    dcterms:source "Anderson, D. (2010). Kanban: Successful Evolutionary Change. Blue Hole Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    owl:equivalentClass meta:KanbanOntologyFlow ;
    skos:definition """A pull-based workflow management method adapted for software
        development by David Anderson, visualising work through a Kanban board
        with explicit Work-In-Progress (WIP) limits to improve flow and expose
        bottlenecks."""@en .

agile:MoSCoWPriority a owl:Class ;
    rdfs:label "MoSCoW Priority"@en ;
    dcterms:source "Stapleton, J. (1997). DSDM: Dynamic Systems Development Method. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition """A prioritisation taxonomy from DSDM categorising backlog items as:
        Must-have (essential for release), Should-have (high value but not critical),
        Could-have (nice to have, included if capacity permits), Won't-have this time
        (agreed out of scope for current release)."""@en .

agile:ProductOwner a owl:Class ;
    rdfs:label "Product Owner"@en ;
    agile:upholds agile:ManifestoPrinciple1,
        agile:ManifestoPrinciple4 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:manages ;
            owl:someValuesFrom agile:ProductBacklog ],
        agile:ScrumRole,
        core:Stakeholder ;
    skos:definition """The single accountable individual responsible for maximising
        the value of the product, managing and ordering the Product Backlog,
        creating product vision and roadmap, and representing stakeholder
        interests to the Scrum Team."""@en .

agile:Release a owl:Class ;
    rdfs:label "Release"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:composedOf ;
            owl:someValuesFrom agile:ProductIncrement ],
        agile:AgileArtefact ;
    skos:definition """A framework-neutral decision and event through which accumulated Done
        Product Increments are deployed or shipped to customers. A Release may occur
        every Sprint, every Program Increment, or at any other cadence determined by
        the Product Owner and organisational context."""@en .

agile:Requirement a owl:Class ;
    rdfs:label "Requirement"@en ;
    dcterms:source "ISO/IEC/IEEE 29148:2018. Systems and Software Engineering — Life Cycle Processes — Requirements Engineering."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogItem ;
    skos:closeMatch qc:Requirement ;
    skos:definition """A statement of a stakeholder need, system behaviour, or quality
        attribute that must be satisfied by the solution. Requirements are the
        parent class for Functional Requirements, Non-Functional Requirements,
        Business Rules, Constraints, and Expectations."""@en .

agile:Task a owl:Class ;
    rdfs:label "Task"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:BacklogItem ;
    skos:definition """The atomic unit of work decomposed from a User Story during
        Sprint Planning, sized to be completed within one day or less, tracked
        in the Sprint Backlog with daily remaining-effort updates."""@en .

agile:XPPractice a owl:Class ;
    rdfs:label "XP Practice"@en ;
    dcterms:source "Beck, K. (1999). Extreme Programming Explained. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue agile:XPFrameworkInd ;
            owl:onProperty agile:belongsToFramework ],
        agile:AgilePractice ;
    skos:definition """One of the fourteen specific practices defined by Extreme
        Programming, organised into primary (e.g., TDD, Pair Programming) and
        corollary (e.g., incremental deployment, root cause analysis) categories."""@en .

agile:decomposesInto a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "decomposes into"@en ;
    dcterms:source "Cohn, M. (2004). User Stories Applied. Addison-Wesley."@en ;
    rdfs:domain agile:BacklogItem,
        agile:Epic,
        agile:Feature,
        agile:Theme,
        agile:UserStory ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:BacklogItem,
        agile:Epic,
        agile:Feature,
        agile:Task,
        agile:UserStory ;
    skos:definition "Hierarchical decomposition relationship between backlog items: Epic decomposesInto UserStory, UserStory decomposesInto Task."@en .

agile:AgileStandard a owl:Class ;
    rdfs:label "Agile Standard"@en ;
    dcterms:source "PMI (2017). Agile Practice Guide. Project Management Institute. https://www.pmi.org/"@en ;
    rdfs:comment "Bridge candidate for pm_classic:Standard in future chapter"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition """A formal document or body of knowledge issued by a
        recognised standards organisation or professional association that
        prescribes, guides, or endorses agile project management practices."""@en .

agile:ArtefactState a owl:Class ;
    rdfs:label "Artefact State"@en ;
    agile:implementsPrinciple agile:ManifestoPrinciple12,
        agile:ManifestoPrinciple7 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:comment "Bridge candidate for core:LifecycleState — rdfs:subClassOf declared."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf core:LifecycleState ;
    skos:definition "An abstract parent class for all lifecycle state classifications applied to Agile work artefacts. Concrete subclasses include BacklogItemState, TaskStatus, SprintGoalState, and ProductRoadmapState. Provides a common anchor for the state machine axioms that govern agile workflow transitions."@en .

agile:Commitment a owl:Class ;
    rdfs:label "Artefact Commitment"@en ;
    agile:implementsPrinciple agile:ManifestoPrinciple3,
        agile:ManifestoPrinciple7 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ScrumArtefact ;
    skos:definition """A formally named objective or quality standard associated
        with a Scrum artefact that increases transparency and provides focus
        for the team's work: Product Goal (Product Backlog), Sprint Goal
        (Sprint Backlog), Definition of Done (Increment)."""@en .

agile:Impediment a owl:Class ;
    rdfs:label "Impediment"@en ;
    agile:removedBy agile:ScrumMaster ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition "Any obstacle, blocker, or systemic issue that prevents a team from making progress toward the Sprint Goal or delivering value. Impediments are raised during the Daily Scrum, tracked by the Scrum Master, and removed through servant leadership within or outside the team."@en .

agile:ProductionParadigm a owl:Class ;
    rdfs:label "Production Paradigm"@en ;
    dcterms:source "Womack, J.P., Jones, D.T. and Roos, D. (1990). The Machine That Changed the World. Free Press."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition """A dominant model or philosophy governing how products are
        conceived, designed, and manufactured within a given historical era,
        reflecting underlying assumptions about labour, quality, and customer value."""@en .

agile:ScalingFramework a owl:Class ;
    rdfs:label "Agile Scaling Framework"@en ;
    dcterms:source "Larman, C. and Vodde, B. (2016). Large-Scale Scrum: More with LeSS. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileFramework ;
    skos:definition """An agile framework specifically designed to coordinate
        multiple agile teams working on a single product or programme,
        addressing dependency management, synchronisation, and enterprise alignment."""@en .

agile:ScrumRole a owl:Class ;
    rdfs:label "Scrum Role"@en ;
    agile:expressesValue agile:ManifestoValue_IndividualsOverProcesses ;
    agile:upholds agile:ManifestoPrinciple11,
        agile:ManifestoPrinciple5 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileRole ;
    skos:definition """One of the three formally defined accountability roles
        in the Scrum framework: Product Owner, Scrum Master, or Developer,
        each carrying distinct responsibilities within the Scrum Team."""@en .

agile:SprintGoalState a owl:Class ;
    rdfs:label "Sprint Goal State"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ArtefactState ;
    skos:definition "The lifecycle state of a Sprint Goal: Active (Sprint in progress), Met (Increment produced and Goal achieved), NotMet (Sprint ended without achieving the Goal), or Abandoned (Sprint cancelled before completion). The Sprint Goal state governs what happens in the Sprint Review."@en .

agile:UserStory a owl:Class ;
    rdfs:label "User Story"@en ;
    dcterms:source "Cohn, M. (2004). User Stories Applied. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:decomposesInto ;
            owl:someValuesFrom agile:Task ],
        agile:BacklogItem ;
    skos:definition """An informal, natural-language description of a software feature
        written from the perspective of the end user or customer, following the
        format: 'As a [role], I want [capability], so that [benefit]', serving
        as a placeholder for conversation rather than a complete specification."""@en .

agile:TaskStatus a owl:Class ;
    rdfs:label "Task Status"@en ;
    dcterms:source "Microsoft (2024). Azure DevOps Scrum process. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:comment "Bridge candidate for JIRA/Azure DevOps TaskStatus enum — tooling alignment."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:ArtefactState ;
    skos:definition "The lifecycle state of a Task within a Sprint, which progresses at finer granularity than the parent BacklogItem. Typical states: To Do → In Progress → In Review → Done. Task status updates are tracked on the Sprint Taskboard and feed the Sprint Burndown Chart."@en .

agile:hasCommitment a owl:ObjectProperty ;
    rdfs:label "has commitment"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:domain agile:ProductBacklog,
        agile:ProductIncrement,
        agile:ScrumArtefact,
        agile:SprintBacklog ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:range agile:Commitment,
        agile:DefinitionOfDone,
        agile:ProductGoalClass,
        agile:SprintGoal ;
    skos:definition "Relates a Scrum artefact to its canonical commitment object: ProductBacklog → ProductGoal; SprintBacklog → SprintGoal; Increment → DefinitionOfDone."@en .

agile:LeanPrinciple a owl:Class ;
    rdfs:label "Lean Principle"@en ;
    dcterms:source "Poppendieck, M. and Poppendieck, T. (2003). Lean Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:LeanSoftwareDevelopment ;
    skos:definition """One of the seven principles of Lean Software Development
        derived from Lean Manufacturing practice, each targeting a specific
        category of waste or value-creation mechanism."""@en .

agile:ManifestoValue a owl:Class ;
    rdfs:label "Manifesto Value"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileManifesto ;
    skos:definition """One of the four declarative value preferences articulated
        in the Agile Manifesto, each structured as a preference between two
        legitimate goods rather than an absolute prohibition."""@en .

agile:ProductBacklog a owl:Class ;
    rdfs:label "Product Backlog"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue agile:ProductGoal ;
            owl:onProperty agile:hasCommitment ],
        agile:ScrumArtefact ;
    skos:definition """The single, emergent, ordered list of everything known to be
        needed in the product, serving as the sole source of requirements for
        changes made to the product. Owned exclusively by the Product Owner."""@en .

agile:ScrumMaster a owl:Class ;
    rdfs:label "Scrum Master"@en ;
    agile:upholds agile:ManifestoPrinciple11,
        agile:ManifestoPrinciple5 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:facilitates ;
            owl:someValuesFrom agile:ScrumEvent ],
        agile:ScrumRole ;
    skos:definition """The servant-leader of the Scrum Team responsible for ensuring
        that Scrum theory and practices are understood and enacted, removing
        impediments to team progress, coaching team members toward self-organisation,
        and working with other Scrum Masters across the organisation."""@en .

agile:SprintBacklog a owl:Class ;
    rdfs:label "Sprint Backlog"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue agile:SprintGoal ;
            owl:onProperty agile:hasCommitment ],
        agile:ScrumArtefact ;
    skos:definition """The set of Product Backlog items selected for the Sprint,
        plus the plan for delivering the Product Increment and realising the
        Sprint Goal. Owned solely by the Developers and updated throughout
        the Sprint."""@en .

agile:AgileManifesto a owl:Class ;
    rdfs:label "Agile Manifesto"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition """The foundational document of the agile movement, produced
        at the Snowbird meeting in February 2001 by seventeen practitioners,
        comprising four core value statements and twelve guiding principles
        that define the philosophical basis of agile software development."""@en .

agile:GherkinScenario a owl:Class ;
    rdfs:label "Gherkin Scenario"@en ;
    dcterms:source "Agile Alliance (2020). Glossary: Given-When-Then. https://www.agilealliance.org/glossary/given-when-then/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://agilealliance.org/glossary/given-when-then/> ;
    rdfs:subClassOf agile:AcceptanceCriteria ;
    skos:definition """A Given-When-Then acceptance test scenario written in BDD Gherkin syntax,
        specifying observable system behaviour: Given (precondition/context),
        When (triggering action), Then (expected outcome). Invented by Aslak Hellesøy
        to support Cucumber; adopted as the Agile Alliance standard for acceptance criteria."""@en .

agile:ScrumArtefact a owl:Class ;
    rdfs:label "Scrum Artefact"@en ;
    agile:expressesValue agile:ManifestoValue_WorkingSoftwareOverDocumentation ;
    agile:implementsPrinciple agile:ManifestoPrinciple3 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileArtefact ;
    skos:definition """One of the three formal Scrum artefacts designed to maximise
        transparency of key information: Product Backlog (commitment: Product Goal),
        Sprint Backlog (commitment: Sprint Goal),
        Product Increment (commitment: Definition of Done)."""@en .

agile:RelatedOntology a owl:Class ;
    rdfs:label "Related Ontology"@en ;
    dcterms:source "Falbo, R.A. et al. (2015). The Software Engineering Ontology Network. FOIS 2014."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition """A formal ontology, meta-model, or semantic vocabulary
        from the literature that covers concepts overlapping with or related
        to agile project management, used for alignment and interoperability."""@en .

agile:BacklogItemState a owl:Class ;
    rdfs:label "Backlog Item State"@en ;
    dcterms:source "Microsoft (2024). Scrum process workflow. Azure DevOps Boards. https://learn.microsoft.com/en-us/azure/devops/boards/work-items/guidance/scrum-process-workflow"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement,
        agile:ArtefactState ;
    skos:definition """A lifecycle state in the progression of a backlog item from inception
        to completion: New → Refined → Ready → InProgress → Done. The transition
        from Refined to Ready requires satisfying the Definition of Ready; the
        transition to Done requires satisfying the Definition of Done."""@en .

agile:TeamMember a owl:Class ;
    rdfs:label "Team Member"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileRole ;
    skos:definition "Any individual who is a contributing member of an Agile team regardless of their functional specialisation. In Scrum, all non-PO/SM contributors are Developers in the Scrum Guide 2020 sense. In practice, team members hold functional titles such as analyst, designer, or tester."@en .

agile:ProductIncrement a owl:Class ;
    rdfs:label "Product Increment"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:hasCommitment ;
            owl:someValuesFrom agile:DefinitionOfDone ],
        agile:ScrumArtefact ;
    skos:definition """The sum of all Product Backlog items completed during a Sprint
        and the value of increments from all prior Sprints. Must be in a usable,
        Done condition regardless of whether the Product Owner decides to release it."""@en .

agile:Sprint a owl:Class ;
    rdfs:label "Sprint"@en ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty agile:producesIncrement ;
            owl:someValuesFrom agile:ProductIncrement ],
        agile:ScrumEvent ;
    skos:definition """A time-boxed iteration of one month or less during which
        a Done, usable, and potentially releasable Product Increment is created.
        Sprints have consistent durations and a new Sprint starts immediately
        after the conclusion of the previous Sprint."""@en .

agile:AgilePrinciple a owl:Class ;
    rdfs:label "Agile Principle"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. Principles. https://agilemanifesto.org/principles.html"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileManifesto ;
    skos:definition """One of the twelve operational guidelines accompanying the
        Agile Manifesto that translate the four core values into actionable
        software development guidance."""@en .

agile:AgileRole a owl:Class ;
    rdfs:label "Agile Role"@en ;
    agile:expressesValue agile:ManifestoValue_IndividualsOverProcesses ;
    agile:upholds agile:ManifestoPrinciple11,
        agile:ManifestoPrinciple5 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. Scrum.org. https://scrumguides.org/"@en ;
    rdfs:comment "Bridge candidate for COM0463 synthesis: shared with pm_classic:ProjectRole."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf core:Role ;
    skos:definition """A defined function or responsibility held by an individual or
        group within an agile delivery framework, characterised by accountability
        for specific outcomes rather than task-level authority."""@en .

agile:ScrumEvent a owl:Class ;
    rdfs:label "Scrum Event"@en ;
    agile:expressesValue agile:ManifestoValue_IndividualsOverProcesses ;
    agile:implementsPrinciple agile:ManifestoPrinciple1,
        agile:ManifestoPrinciple12,
        agile:ManifestoPrinciple3 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. https://scrumguides.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf core:Process ;
    skos:closeMatch <http://schema.org/Event> ;
    skos:definition """One of the five formal, time-boxed opportunities in Scrum
        that create regularity and minimise the need for unplanned meetings:
        Sprint, Sprint Planning, Daily Scrum, Sprint Review, Sprint Retrospective."""@en .

agile:AgileMetric a owl:Class ;
    rdfs:label "Agile Metric"@en ;
    agile:implementsPrinciple agile:ManifestoPrinciple12,
        agile:ManifestoPrinciple7 ;
    dcterms:source "Cohn, M. (2005). Agile Estimating and Planning. Prentice Hall."@en ;
    rdfs:comment "Bridge candidate for COM0463 synthesis: shared with pm_cost:EarnedValueMetric."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf core:Metric ;
    skos:definition """A quantitative or qualitative measure used in agile project
        management to assess progress, team performance, product quality, or
        delivery predictability, derived from empirical observations of sprint
        and release execution."""@en .

agile:ManifestoPrincipleClass a owl:Class ;
    rdfs:label "Manifesto Principle"@en ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileManifestoPrinciple ;
    skos:definition "The class of all 12 principles from the Agile Manifesto (2001), which operationalise the four Manifesto Values into concrete guidance for teams. The 12 principles cover early delivery, welcoming change, frequent delivery, collaboration, motivation, direct communication, working software as progress, sustainable pace, technical excellence, simplicity, self-organisation, and regular reflection."@en ;
    skos:exactMatch <http://agilemanifesto.org/principles.html> .

agile:AgileFramework a owl:Class ;
    rdfs:label "Agile Framework"@en ;
    agile:manifestoSource agile:AgileManifesto ;
    dcterms:source "Digital.ai (2022). 16th Annual State of Agile Report. https://digital.ai/resource-center/analyst-reports/state-of-agile-report/"@en ;
    rdfs:comment "Bridge candidate for meta:AgileMethodology — equivalence declared"@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    owl:equivalentClass meta:AgileMethodology ;
    skos:definition """A structured collection of values, roles, events, artefacts,
        and practices that operationalises agile principles within a specific
        methodological context (e.g., Scrum, XP, Kanban, SAFe, LeSS)."""@en .

agile:AgileProjectManagement a owl:Class ;
    rdfs:label "Agile Project Management"@en ;
    agile:groundedIn agile:AgileManifesto ;
    dcterms:source "Beck, K. et al. (2001). Manifesto for Agile Software Development. https://agilemanifesto.org/"@en ;
    rdfs:comment "Bridge candidate for COM0463 synthesis: top-level entry point."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:seeAlso <https://agilemanifesto.org/> ;
    skos:definition """The discipline of managing software and product development
        projects using iterative, incremental, and adaptive approaches grounded
        in the Agile Manifesto values and principles, emphasising customer
        collaboration, working software, and responsiveness to change over
        rigid plan-driven execution."""@en .

agile:AgileArtefact a owl:Class ;
    rdfs:label "Agile Artefact"@en ;
    agile:expressesValue agile:ManifestoValue_WorkingSoftwareOverDocumentation ;
    agile:implementsPrinciple agile:ManifestoPrinciple7 ;
    dcterms:source "Schwaber, K. and Sutherland, J. (2020). The Scrum Guide. Scrum.org. https://scrumguides.org/"@en ;
    rdfs:comment "Bridge candidate for COM0463 synthesis: shared with pm_classic:ProjectArtefact."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileProjectManagement ;
    skos:definition """A tangible work product produced or maintained during agile
        delivery that embodies transparency, provides a basis for inspection,
        and enables adaptation of the development process."""@en .

agile:BacklogItem a owl:Class ;
    rdfs:label "Backlog Item"@en ;
    agile:expressesValue agile:ManifestoValue_CustomerCollaborationOverNegotiation,
        agile:ManifestoValue_ResponseToChangeOverPlan ;
    agile:implementsPrinciple agile:ManifestoPrinciple1 ;
    dcterms:source "Cohn, M. (2004). User Stories Applied: For Agile Software Development. Addison-Wesley."@en ;
    rdfs:isDefinedBy <http://example.org/agile> ;
    rdfs:subClassOf agile:AgileArtefact ;
    skos:definition """A unit of work recorded in the Product Backlog representing
        a requirement, feature, bug fix, enhancement, or technical task needed
        in the product, ordered by value and refined progressively as delivery approaches."""@en .

<http://example.org/agile> a owl:Ontology ;
    rdfs:label "Ontology4Agile — Agile Project Management Ontology"@en ;
    agile:governanceModel redo: ;
    agile:verifiedUnder redo:ComplianceGate ;
    dcterms:created "2026-03-06"^^xsd:date ;
    dcterms:creator "Yusuf Altunel, PhD — Istanbul Kültür University, Computer Engineering"@en ;
    dcterms:description """OWL 2 DL ontology covering Agile Project Management
        concepts for the COM0463 IT Project Management course, Chapter: Agile PM.
        Part of the COM0463 ontology ecosystem. Ecosystem position: Chapter 1 of N.
        Imports: core v1.1.0. Aligns with: meta v6.1.0, oqc v2.1.0, redo v2.4.6.
        Future chapters: pm_classic (PMBOK/Waterfall/PRINCE2), pm_risk (RAID),
        pm_cost (EVM/Budgeting), pm_quality (ISO 25010/SQuaRE),
        pm_tools (Jira/Azure DevOps/GitHub).
        Synthesis target: COM0463_ITProjectMgmt (owl:imports all chapters).
        Primary sources: Agile Manifesto (2001), Scrum Guide (2020),
        COM0463 course chapter by Yusuf Altunel PhD."""@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:source <https://agilemanifesto.org/>,
        <https://scrumguides.org/>,
        <https://www.pmi.org/pmbok-guide-standards> ;
    dcterms:subject "Agile Project Management, Scrum, XP, Kanban, SAFe, LeSS, COM0463"@en ;
    dcterms:title "Ontology4Agile v1.3.0 — Philosophy-Grounded, Relationally Complete Agile Ontology"@en ;
    rdfs:comment "BS-12-1: Role authority modelling (RACI) — Responsible/Accountable/Consulted/Informed axes not modelled. agile:ownedBy covers Accountable only; a formal RACI ontology requires a separate pm_governance: module."@en,
        "BS-12-2: Capacity planning — agile:isFullTime and agile:yearsExperience are proxies for capacity but a full capacity model (allocation percentages, sprint capacity hours, time-off, holidays) is outside scope. Reserved for pm_resource: chapter."@en,
        "BS-12-3: Skill taxonomy — 'requires skill' relates to a TeamMember class, not a controlled skill vocabulary. A proper skills ontology (ESCO, SFIA) would be needed for formal skill-gap analysis."@en,
        "BS-12-4: State machine completeness — the transitionsTo property defines allowed transitions as an open-world graph, not a closed state machine. An OWL reasoner cannot derive that State_Done → State_InProgress is forbidden without SWRL rules or SPARQL SPIN constraints. Formal state machine closure is a known OWL 2 DL limit."@en,
        "BS-12-5: Dual-Track Agile / Discovery track — UXDesigner's 'Sprint Zero' practice and Discovery backlog are not modelled as formal concepts. Reserved for future pm_discovery: chapter co-developed with the UX community."@en,
        "BS-13-1: Philosophy grounding is ASSERTED not REASONED — the groundedIn, upholds, and implementsPrinciple triples are explicit ABox assertions on abstract parent classes. An OWL 2 DL reasoner propagates them to subclasses via rdfs:subClassOf entailment ONLY if a reasoner is invoked. Without a reasoner, the reachability gain is BFS-implied but not formally entailed."@en,
        "BS-13-2: ManifestoValueClass and ManifestoPrincipleClass are synthetic classes added to provide typed anchors for the 12+4 named individuals. The Agile Manifesto itself does not publish an OWL ontology; the URIs used here are convention, not authoritative namespace resolutions."@en,
        "BS-13-3: facilitatedBy is asserted between Event class and Role class (TBox level), not between specific Sprint instances and team member instances (ABox level). Instance-level facilitation records require a Sprint Management System (Jira, Azure DevOps) as the authoritative data source."@en,
        "BS-P1: SAFe Portfolio Kanban, EpicHypothesis, LeanBusinessCase, PortfolioBacklog — reserved for future pm_portfolio: chapter. Omitted here to maintain module boundary discipline."@en,
        "BS-P2: OKR/PI Objective integration — SAFe 6.0 maps OKRs to PI Objectives; not modelled here as OKR framework belongs in pm_strategy: chapter."@en,
        "BS-P3: BDD toolchain (Cucumber, SpecFlow, Behave) not modelled as named individuals — tool landscape changes rapidly and tool claims require version-locked sourcing."@en,
        "BS-P4: Agile contracting and hybrid governance (time-and-materials + story point guarantees) are outside scope; reserved for pm_classic: chapter."@en,
        "BS-P5: WorkPackage bridging — agile:ProgramIncrement skos:closeMatch pm_classic:WorkPackage intended but pm_classic: does not yet exist. Documented in rdfs:comment on ProgramIncrement only."@en,
        "BS-P6: Kanban Replenishment Meeting and Kanban Cadences (service delivery review, operations review, risk review) not modelled — these are Kanban Method events beyond the core four Kanban meetings and overlap with ScrumEvent hierarchy."@en,
        "BS-P7: Team Topologies (Team API, stream-aligned, platform, enabling, complicated subsystem teams — Skelton & Pais 2019) not modelled. While increasingly referenced in SAFe literature, formal ontology integration requires a dedicated teamtopology: module."@en,
        "COM0463 Ontology Ecosystem — Chapter 1: Agile PM. Bridge candidates for synthesis: agile:AgileRole, agile:AgileArtefact, agile:AgileMetric, agile:AgileFramework, agile:AgileStandard."@en ;
    owl:imports <http://example.org/core>,
        meta:,
        qc:,
        redo: ;
    owl:priorVersion <http://example.org/agile/v0.0.0> ;
    owl:versionIRI <http://example.org/agile/v1.3.0> ;
    owl:versionInfo "1.3.0" .

[] a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:maxCount 5 ;
            sh:message "AGILE [FLOW]: BacklogItem must not reference more than 5 impediments simultaneously."@en ;
            sh:path agile:blockedBy ] ;
    sh:targetClass agile:BacklogItem .

[] a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:message "AGILE [LIFECYCLE]: Task must declare hasTaskStatus."@en ;
            sh:minCount 1 ;
            sh:path agile:hasTaskStatus ] ;
    sh:targetClass agile:Task .

[] a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:message "AGILE [ROLE]: TeamMember must declare hasRole."@en ;
            sh:minCount 1 ;
            sh:path agile:hasRole ] ;
    sh:targetClass agile:TeamMember .

[] a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:message "AGILE [INTEGRITY]: SprintBacklog must have at least one hasCommitment (SprintGoal)."@en ;
            sh:minCount 1 ;
            sh:path agile:hasCommitment ] ;
    sh:targetClass agile:SprintBacklog .

[] a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:message "AGILE [INTEGRITY]: ProductIncrement must have at least one hasCommitment (DefinitionOfDone)."@en ;
            sh:minCount 1 ;
            sh:path agile:hasCommitment ] ;
    sh:targetClass agile:ProductIncrement .

[] a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:message "AGILE [INTEGRITY]: ProductBacklog must have at least one hasCommitment (ProductGoal)."@en ;
            sh:minCount 1 ;
            sh:path agile:hasCommitment ] ;
    sh:targetClass agile:ProductBacklog .

[] a sh:PropertyShape ;
    sh:message "AGILE [INTEGRITY]: ScrumArtefact must have exactly one agile:hasCommitment."@en ;
    sh:minCount 1 ;
    sh:path agile:hasCommitment .

