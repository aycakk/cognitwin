#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :AccountantAgent
                :CDOAgent
                :FashionBuyerAgent
                :FinanceManagerAgent
                :ProjectManagerAgent
                :RecruiterAgent
                :RetailStoreManagerAgent
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :HeadOfDepartmentAgent
                :InstructorAgent
                :ResearcherAgent
                :StudentAgent
              )
] .


