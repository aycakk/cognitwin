:FashionBuyerAgent rdf:type owl:Class ;
                   rdfs:subClassOf :Agent .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/FinanceManagerAgent
:FinanceManagerAgent rdf:type owl:Class ;
                     rdfs:subClassOf :Agent .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/HeadOfDepartmentAgent
:HeadOfDepartmentAgent rdf:type owl:Class ;
                       rdfs:subClassOf :Agent .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/InstructorAgent
:InstructorAgent rdf:type owl:Class ;
                 rdfs:subClassOf :Agent .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/MaskLabel
:MaskLabel rdf:type owl:Class .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/Message
:Message rdf:type owl:Class ;
         rdfs:subClassOf :Artifact .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/Organization
:Organization rdf:type owl:Class .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/PIIElement
:PIIElement rdf:type owl:Class ;
            rdfs:subClassOf [ rdf:type owl:Restriction ;
                              owl:onProperty :hasMaskLabel ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass :MaskLabel
                            ] .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/Person
:Person rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasAgent ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Agent
                        ] .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/ProjectManagerAgent
:ProjectManagerAgent rdf:type owl:Class ;
                     rdfs:subClassOf :Agent .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/RecruiterAgent
:RecruiterAgent rdf:type owl:Class ;
                rdfs:subClassOf :Agent .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/ResearcherAgent
:ResearcherAgent rdf:type owl:Class ;
                 rdfs:subClassOf :Agent .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/RetailStoreManagerAgent
:RetailStoreManagerAgent rdf:type owl:Class ;
                         rdfs:subClassOf :Agent .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/StudentAgent
:StudentAgent rdf:type owl:Class ;
              rdfs:subClassOf :Agent .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/Task
:Task rdf:type owl:Class .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/Time
:Time rdf:type owl:Class .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/TimeInstant
:TimeInstant rdf:type owl:Class ;
             rdfs:subClassOf :Time ;
             owl:disjointWith :TimeInterval .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/TimeInterval
:TimeInterval rdf:type owl:Class ;
              rdfs:subClassOf :Time .


