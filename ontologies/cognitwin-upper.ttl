###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/maskCategory
:maskCategory rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :MaskLabel ;
              rdfs:range xsd:string .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/maskText
:maskText rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:domain :MaskLabel ;
          rdfs:range xsd:string .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/status
:status rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdfs:domain :Task ;
        rdfs:range xsd:string .


###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/timestamp
:timestamp rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
