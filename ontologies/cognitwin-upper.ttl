###  http://www.semanticweb.org/47ila/ontologies/2026/1/untitled-ontology-7/aboutAgent
:aboutAgent rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain :Artifact ;
            rdfs:range :Agent .


